# Generated by openclaw-deploy ansible
# OTel Collector config — receives OTLP, fans out to Phoenix + Prometheus

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: "{{ telemetry.host }}:{{ telemetry.otel_collector.grpc_port }}"
      http:
        endpoint: "{{ telemetry.host }}:{{ telemetry.otel_collector.http_port }}"

processors:
  batch:
    send_batch_size: 512
    timeout: 5s

  # Add resource attributes for easier filtering
  resource:
    attributes:
      - key: deployment.environment
        value: "openclaw-hardened"
        action: upsert

exporters:
  # Traces -> Phoenix
  otlphttp/phoenix:
    endpoint: "http://{{ telemetry.host }}:{{ telemetry.phoenix.port }}"
    tls:
      insecure: true

  # Metrics -> Prometheus (collector exposes /metrics for Prometheus to scrape)
  prometheus:
    endpoint: "{{ telemetry.host }}:8889"
    namespace: "otel"
    resource_to_telemetry_conversion:
      enabled: true

  # Debug logging (disable in production by removing from pipelines)
  debug:
    verbosity: basic
    sampling_initial: 5
    sampling_thereafter: 200

service:
  pipelines:
    traces:
      receivers: [otlp]
      processors: [batch, resource]
      exporters: [otlphttp/phoenix]

    metrics:
      receivers: [otlp]
      processors: [batch, resource]
      exporters: [prometheus]

  telemetry:
    logs:
      level: info
    metrics:
      address: "{{ telemetry.host }}:8898"
