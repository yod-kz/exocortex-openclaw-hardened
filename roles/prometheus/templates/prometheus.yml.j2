# Generated by openclaw-deploy ansible
global:
  scrape_interval: {{ telemetry.prometheus.scrape_interval }}
  evaluation_interval: {{ telemetry.prometheus.scrape_interval }}

scrape_configs:
  # OTel Collector's Prometheus exporter (all service metrics flow here)
  - job_name: "otel-collector-metrics"
    static_configs:
      - targets: ["{{ telemetry.host }}:8889"]
        labels:
          source: "otel-collector"

  # OTel Collector's own internal metrics
  - job_name: "otel-collector-internal"
    static_configs:
      - targets: ["{{ telemetry.host }}:8898"]
        labels:
          source: "otel-collector-internal"

  # Prometheus self-monitoring
  - job_name: "prometheus"
    static_configs:
      - targets: ["{{ telemetry.host }}:{{ telemetry.prometheus.port }}"]
