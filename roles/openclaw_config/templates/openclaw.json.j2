{# Filter endpoints: LAN always active, cloud only if key is configured #}
{% set _eps = [] %}
{% for ep in inference.endpoints %}
{%   if ep.api_key | default('not-required') != '' %}
{%     set _ = _eps.append(ep) %}
{%   endif %}
{% endfor %}
{% set _locksmith_base_url = locksmith.openclaw_base_url | default('') %}
{% if _locksmith_base_url == '' %}
{%   set _locksmith_base_url = 'http://' ~ (locksmith.listen_host | default('127.0.0.1')) ~ ':' ~ (locksmith.listen_port | default(9200)) %}
{% endif %}
{% set _slack_native = locksmith.slack_native | default({}) %}
{% set _slack_credential_transport_enabled = (locksmith.enabled | default(true)) and (_slack_native.enabled | default(true)) %}
{% set _slack_bot_tool_name = _slack_native.bot_tool_name | default('slack-bot') %}
{% set _slack_app_tool_name = _slack_native.app_tool_name | default('slack-app') %}
{% set _slack_user_tool_name = _slack_native.user_tool_name | default('slack-user') %}
{% set _memory_cfg = openclaw_memory | default({}) %}
{% set _memory_qmd = _memory_cfg.qmd | default({}) %}
{% set _memory_qmd_enabled = _memory_qmd.enabled | default(false) %}
{% set _memory_active = _memory_cfg.active_memory | default({}) %}
{% set _memory_dreaming = _memory_cfg.dreaming | default({}) %}
{# ── Agent-scoped channel accounts ───────────────────────────────── #}
{# Collect agents that define their own Slack or Telegram identity.   #}
{# Each entry: {agent: <agent dict>, slack: <merged>, telegram: <merged>} #}
{% set _agent_slack = [] %}
{% set _agent_telegram = [] %}
{% set _agent_discord = [] %}
{% for agent in openclaw_agents | default([]) %}
{%   if agent.slack is defined and (agent.slack.bot_token | default('') != '' or _slack_credential_transport_enabled) %}
{%     set _slack = _agent_slack_defaults | default({}) | combine(agent.slack, recursive=True) %}
{%     set _ = _agent_slack.append({'agent': agent, 'slack': _slack}) %}
{%   endif %}
{%   if agent.telegram is defined and agent.telegram.bot_token | default('') != '' %}
{%     set _tg = _agent_telegram_defaults | default({}) | combine(agent.telegram, recursive=True) %}
{%     set _ = _agent_telegram.append({'agent': agent, 'telegram': _tg}) %}
{%   endif %}
{%   if agent.discord is defined and agent.discord.bot_token | default('') != '' %}
{%     set _ = _agent_discord.append({'agent': agent, 'discord': agent.discord}) %}
{%   endif %}
{% endfor %}
{# ── Legacy channels (non-agent-scoped, or fallback when no agent defines it) #}
{% set _chans = {} %}
{% for name, cfg in (openclaw_channels | default({})).items() %}
{%   if name == 'slack' and _agent_slack | length > 0 %}
{#     Skip legacy slack — agents own it now #}
{%   elif name == 'telegram' and _agent_telegram | length > 0 %}
{#     Skip legacy telegram — agents own it now #}
{%   elif cfg.botToken | default('') != '' %}
{%     set _ = _chans.update({name: cfg}) %}
{%   endif %}
{% endfor %}
{% set _locksmith_projected_tool_names = [] %}
{% if locksmith.enabled | default(true) %}
{%   for tool in locksmith.tools | default([]) %}
{%     if tool.projected | default(true) and (tool.api_key | default('') != '' or tool.api_key_from_env | default(false) or tool.auth_required | default(true) == false) %}
{%       set _ = _locksmith_projected_tool_names.append(tool.name) %}
{%     endif %}
{%   endfor %}
{% endif %}
{% set _native_slack_configured = _agent_slack | length > 0 or 'slack' in _chans %}
{% set _disable_bundled_slack_skill = not _native_slack_configured and 'slack' in _locksmith_projected_tool_names %}
{# ── Resolve default agent (for workspace path) ─────────────────── #}
{% set _default_agent = openclaw_agents | default([]) | selectattr('default', 'defined') | selectattr('default', 'equalto', true) | first | default(openclaw_agents | default([]) | first | default(none)) %}
{
  "meta": {
    "lastTouchedVersion": "ansible-managed",
    "lastTouchedAt": "{{ ansible_facts['date_time']['iso8601'] }}"
  },
  "models": {
    "mode": "merge",
    "providers": {
{% for ep in _eps %}
{% set _dynamic_catalog = ep.dynamic_catalog | default(ep.provider_name == 'kzproxy') %}
      "{{ ep.provider_name }}": {
{% if llamafirewall.enabled | default(false) %}
        "baseUrl": "http://{{ llamafirewall.connect_host | default(llamafirewall.listen_host) }}:{{ llamafirewall.listen_port }}/{{ ep.provider_name }}/v1",
{% else %}
        "baseUrl": "{{ ep.base_url }}",
{% endif %}
{% if llamafirewall.enabled | default(false) %}
        "apiKey": "not-required",
{% else %}
        "apiKey": "{{ ep.api_key | default('not-required') }}",
{% endif %}
        "api": "{{ ep.api_type }}",
{% if _dynamic_catalog %}
        "models": []
{% else %}
        "models": [
          {
            "id": "{{ ep.model_id }}",
            "name": "{{ ep.model_name }}",
            "reasoning": {{ ep.reasoning | to_json }},
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": {{ ep.context_window }},
            "maxTokens": {{ ep.max_tokens }}
          }
        ]
{% endif %}
      }{{ "," if not loop.last }}
{% endfor %}
    }
  },
  "agents": {
    "defaults": {
{% set primary = _eps | selectattr('primary', 'equalto', true) | first %}
      "model": {
        "primary": "{{ primary.provider_name }}/{{ primary.model_id }}"
      },
      "models": {
{% for ep in _eps %}
{% set _dynamic_catalog = ep.dynamic_catalog | default(ep.provider_name == 'kzproxy') %}
{% if _dynamic_catalog %}
        "{{ ep.provider_name }}/*": {}{{ "," if not loop.last }}
{% else %}
        "{{ ep.provider_name }}/{{ ep.model_id }}": {
          "alias": "{{ ep.model_id | lower | replace('_','-') | replace('/','-') }}"
{% if ep.params is defined %}
          ,"params": {{ ep.params | to_json }}
{% endif %}
        }{{ "," if not loop.last }}
{% endif %}
{% endfor %}
      },
      "workspace": "{{ openclaw_data_dir | default('/home/openclaw/.openclaw') }}/{% if _default_agent %}agents/{{ _default_agent.workspace_subdir | default(_default_agent.id) }}/workspace{% else %}workspace{% endif %}",
      "compaction": {
        "mode": "{{ openclaw.compaction_mode }}"
      },
      "maxConcurrent": {{ openclaw.max_concurrent }},
      "subagents": {
        "maxConcurrent": {{ openclaw.subagent_max_concurrent }}
      },
      "sandbox": {
        "mode": "{{ openclaw.sandbox.mode }}",
        "docker": {
          "network": "{{ openclaw.sandbox.docker_network }}",
          "readOnlyRoot": {{ openclaw.sandbox.read_only_root | to_json }},
          "memory": "{{ openclaw.sandbox.memory }}",
          "cpus": {{ openclaw.sandbox.cpus }},
          "pidsLimit": {{ openclaw.sandbox.pids_limit }}
        }
      }
    }{% if openclaw_agents | default([]) | length > 0 %},
    "list": [
{% for agent in openclaw_agents %}
{% set _agent_memory_cfg = _memory_cfg | combine(agent.memory | default({}), recursive=True) %}
{% set _agent_memory_search_cfg = _agent_memory_cfg.search | default({}) %}
{% set _agent_memory_search_enabled = agent.memory_search | default(_agent_memory_cfg.enabled | default(false)) %}
      {
        "id": "{{ agent.id }}",
        "name": "{{ agent.name | default(agent.id) }}",
{% if agent.default | default(false) %}
        "default": true,
{% endif %}
{% if agent.model is defined %}
        "model": {{ agent.model | to_nice_json(indent=2) }},
{% endif %}
{% if agent.models is defined %}
        "models": {{ agent.models | to_nice_json(indent=2) }},
{% endif %}
{% if agent.context_tokens is defined %}
        "contextTokens": {{ agent.context_tokens | to_json }},
{% endif %}
{% if agent.thinking_default is defined %}
        "thinkingDefault": {{ agent.thinking_default | to_json }},
{% endif %}
{% if agent.verbose_default is defined %}
        "verboseDefault": {{ agent.verbose_default | to_json }},
{% endif %}
{% if agent.params is defined %}
        "params": {{ agent.params | to_nice_json(indent=2) }},
{% endif %}
        "workspace": "{{ openclaw_data_dir | default('/home/openclaw/.openclaw') }}/agents/{{ agent.workspace_subdir | default(agent.id) }}/workspace",
{% if agent.skills is defined %}
        "skills": {{ agent.skills | to_json }},
{% endif %}
        "memorySearch": {
          "enabled": {{ _agent_memory_search_enabled | bool | to_json }},
          "sources": {{ _agent_memory_search_cfg.sources | default(["memory", "sessions"]) | to_json }},
          "extraPaths": [
            "{{ openclaw_data_dir | default('/home/openclaw/.openclaw') }}/shared"
          ]{% if ollama.enabled | default(false) and _agent_memory_search_enabled | bool %},
          "provider": "ollama",
          "remote": {
            "baseUrl": "http://{{ ollama.host | default('127.0.0.1') }}:{{ ollama.port | default(11434) }}"
          }{% endif %}
        }
{% if agent.tools is defined %}
        ,"tools": {{ agent.tools | to_nice_json(indent=2) }}
{% endif %}
{% if agent.subagents is defined %}
        ,"subagents": {{ agent.subagents | to_nice_json(indent=2) }}
{% endif %}
{% if agent.sandbox is defined %}
        ,"sandbox": {{ agent.sandbox | to_nice_json(indent=2) }}
{% endif %}
      }{{ "," if not loop.last }}
{% endfor %}
    ]
{% endif %}
  },
  "tools": {
    "profile": "{{ openclaw.tools_profile }}"
  },
{% if _disable_bundled_slack_skill %}
  "skills": {
    "entries": {
      "slack": {
        "enabled": false
      }
    }
  },
{% endif %}
  "env": {
    "HTTP_PROXY": "{{ openclaw.fetch_proxy }}",
    "HTTPS_PROXY": "{{ openclaw.fetch_proxy }}",
    "NO_PROXY": "localhost,127.0.0.1,172.17.0.1,{{ network.allowed_lan_ips | map(attribute='ip') | join(',') }}{% if openclaw.no_proxy_extra is defined %},{{ openclaw.no_proxy_extra | join(',') }}{% endif %}"
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
{% if _memory_qmd_enabled %}
{% set _memory_qmd_update = _memory_qmd.update | default({}) %}
{% set _memory_qmd_limits = _memory_qmd.limits | default({}) %}
{% set _memory_qmd_sessions = _memory_qmd.sessions | default({}) %}
{% set _qmd_update = {'interval': _memory_qmd_update.interval | default('5m'), 'debounceMs': _memory_qmd_update.debounce_ms | default(15000)} %}
{% if _memory_qmd_update.on_boot is defined %}
{%   set _ = _qmd_update.update({'onBoot': _memory_qmd_update.on_boot}) %}
{% endif %}
{% if _memory_qmd_update.startup is defined %}
{%   set _ = _qmd_update.update({'startup': _memory_qmd_update.startup}) %}
{% endif %}
{% if _memory_qmd_update.startup_delay_ms is defined %}
{%   set _ = _qmd_update.update({'startupDelayMs': _memory_qmd_update.startup_delay_ms}) %}
{% endif %}
{% if _memory_qmd_update.wait_for_boot_sync is defined %}
{%   set _ = _qmd_update.update({'waitForBootSync': _memory_qmd_update.wait_for_boot_sync}) %}
{% endif %}
{% if _memory_qmd_update.embed_interval is defined %}
{%   set _ = _qmd_update.update({'embedInterval': _memory_qmd_update.embed_interval}) %}
{% endif %}
{% if _memory_qmd_update.command_timeout_ms is defined %}
{%   set _ = _qmd_update.update({'commandTimeoutMs': _memory_qmd_update.command_timeout_ms}) %}
{% endif %}
{% if _memory_qmd_update.update_timeout_ms is defined %}
{%   set _ = _qmd_update.update({'updateTimeoutMs': _memory_qmd_update.update_timeout_ms}) %}
{% endif %}
{% if _memory_qmd_update.embed_timeout_ms is defined %}
{%   set _ = _qmd_update.update({'embedTimeoutMs': _memory_qmd_update.embed_timeout_ms}) %}
{% endif %}
{% set _qmd_limits = {'maxResults': _memory_qmd_limits.max_results | default(6), 'timeoutMs': _memory_qmd_limits.timeout_ms | default(4000)} %}
{% if _memory_qmd_limits.max_snippet_chars is defined %}
{%   set _ = _qmd_limits.update({'maxSnippetChars': _memory_qmd_limits.max_snippet_chars}) %}
{% endif %}
{% if _memory_qmd_limits.max_injected_chars is defined %}
{%   set _ = _qmd_limits.update({'maxInjectedChars': _memory_qmd_limits.max_injected_chars}) %}
{% endif %}
{% set _qmd_sessions = {'enabled': _memory_qmd_sessions.enabled | default(false)} %}
{% if _memory_qmd_sessions.retention_days is defined %}
{%   set _ = _qmd_sessions.update({'retentionDays': _memory_qmd_sessions.retention_days}) %}
{% endif %}
{% if _memory_qmd_sessions.export_dir is defined %}
{%   set _ = _qmd_sessions.update({'exportDir': _memory_qmd_sessions.export_dir}) %}
{% endif %}
{% set _qmd_config = {
     'command': _memory_qmd.command | default('qmd'),
     'searchMode': _memory_qmd.search_mode | default('search'),
     'includeDefaultMemory': _memory_qmd.include_default_memory | default(true),
     'update': _qmd_update,
     'limits': _qmd_limits,
     'sessions': _qmd_sessions,
     'scope': _memory_qmd.scope | default({'default': 'deny', 'rules': [{'action': 'allow', 'match': {'chatType': 'direct'}}]})
   } %}
{% if _memory_qmd.rerank is defined %}
{%   set _ = _qmd_config.update({'rerank': _memory_qmd.rerank}) %}
{% endif %}
{% if _memory_qmd.search_tool is defined %}
{%   set _ = _qmd_config.update({'searchTool': _memory_qmd.search_tool}) %}
{% endif %}
{% if _memory_qmd.paths | default([]) | length > 0 %}
{%   set _ = _qmd_config.update({'paths': _memory_qmd.paths}) %}
{% endif %}
  "memory": {
    "backend": "qmd",
    "citations": "{{ _memory_cfg.citations | default('auto') }}",
    "qmd": {{ _qmd_config | to_nice_json(indent=2) | indent(6, false) }}
  },
{% endif %}
{% set _mcp_servers = {} %}
{% if slack_context_mcp.enabled | default(false) %}
{%   set _slack_context_server = {
       'url': 'http://' ~ (slack_context_mcp.listen_host | default('127.0.0.1')) ~ ':' ~ (slack_context_mcp.listen_port | default(13080)) ~ (slack_context_mcp.streamable_http_path | default('/mcp')),
       'transport': 'streamable-http',
       'connectTimeout': slack_context_mcp.connect_timeout | default(10),
       'timeout': slack_context_mcp.timeout | default(90),
       'toolFilter': {
         'include': slack_context_mcp.allowed_tools | default([])
       }
     } %}
{%   set _ = _mcp_servers.update({'slack-context': _slack_context_server}) %}
{% endif %}
  "mcp": {
    "servers": {{ _mcp_servers | to_nice_json(indent=2) | indent(6, false) }}
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
{# Build channels dict: start with legacy channels, add agent-scoped Slack/Telegram #}
{% set _channels_out = {} %}
{% for name, cfg in _chans.items() %}
{%   set _ = _channels_out.update({name: cfg}) %}
{% endfor %}
{% if _agent_slack | length > 0 %}
{%   set _slack_default = _agent_slack | selectattr('agent.default', 'defined') | selectattr('agent.default', 'equalto', true) | first | default(_agent_slack[0]) %}
{%   set _slack_accounts = {} %}
{%   for entry in _agent_slack %}
{%     set _entry_slack_proxy = entry.slack.credential_proxy | default({}) %}
{%     set _entry_slack_proxy_enabled = _entry_slack_proxy.enabled | default(_slack_credential_transport_enabled) %}
{%     if _entry_slack_proxy_enabled %}
{%       set _slack_bot_token = _entry_slack_proxy.bot_handle | default(entry.slack.bot_handle | default('xoxb-locksmith-' ~ entry.agent.id)) %}
{%       set _slack_app_token = _entry_slack_proxy.app_handle | default(entry.slack.app_handle | default('xapp-locksmith-' ~ entry.agent.id)) %}
{%       set _slack_user_token = _entry_slack_proxy.user_handle | default(entry.slack.user_handle | default('')) %}
{%       if _slack_user_token == '' and (_slack_native.include_user | default(false) or entry.slack.user_token | default('') != '') %}
{%         set _slack_user_token = 'xoxp-locksmith-' ~ entry.agent.id %}
{%       endif %}
{%     else %}
{%       set _slack_bot_token = entry.slack.bot_token %}
{%       set _slack_app_token = entry.slack.app_token | default('') %}
{%       set _slack_user_token = entry.slack.user_token | default('') %}
{%     endif %}
{%     set _slack_streaming = entry.slack.streaming | default({'mode': 'partial'}) %}
{%     if _slack_streaming is string %}
{%       set _slack_streaming = {'mode': _slack_streaming} %}
{%     endif %}
{%     set _slack_acct = {
         'name': entry.agent.name | default(entry.agent.id),
         'mode': entry.slack.mode | default('socket'),
         'botToken': _slack_bot_token,
         'appToken': _slack_app_token,
         'groupPolicy': entry.slack.group_policy | default('allowlist'),
         'streaming': _slack_streaming
       } %}
{%     if entry.slack.account_config is defined %}
{%       set _ = _slack_acct.update(entry.slack.account_config) %}
{%     endif %}
{%     if entry.slack.enabled is defined %}
{%       set _ = _slack_acct.update({'enabled': entry.slack.enabled}) %}
{%     endif %}
{%     if entry.slack.dm_policy is defined %}
{%       set _ = _slack_acct.update({'dmPolicy': entry.slack.dm_policy}) %}
{%     endif %}
{%     if entry.slack.allow_from is defined %}
{%       set _ = _slack_acct.update({'allowFrom': entry.slack.allow_from}) %}
{%     endif %}
{%     if entry.slack.default_to is defined %}
{%       set _ = _slack_acct.update({'defaultTo': entry.slack.default_to}) %}
{%     endif %}
{%     if entry.slack.dm is defined %}
{%       set _ = _slack_acct.update({'dm': entry.slack.dm}) %}
{%     endif %}
{%     if entry.slack.dms is defined %}
{%       set _ = _slack_acct.update({'dms': entry.slack.dms}) %}
{%     endif %}
{%     if entry.slack.channels is defined %}
{%       set _ = _slack_acct.update({'channels': entry.slack.channels}) %}
{%     endif %}
{%     if entry.slack.allow_bots is defined %}
{%       set _ = _slack_acct.update({'allowBots': entry.slack.allow_bots}) %}
{%     endif %}
{%     if entry.slack.require_mention is defined %}
{%       set _ = _slack_acct.update({'requireMention': entry.slack.require_mention}) %}
{%     endif %}
{%     if entry.slack.context_visibility is defined %}
{%       set _ = _slack_acct.update({'contextVisibility': entry.slack.context_visibility}) %}
{%     endif %}
{%     if entry.slack.history_limit is defined %}
{%       set _ = _slack_acct.update({'historyLimit': entry.slack.history_limit}) %}
{%     endif %}
{%     if entry.slack.dm_history_limit is defined %}
{%       set _ = _slack_acct.update({'dmHistoryLimit': entry.slack.dm_history_limit}) %}
{%     endif %}
{%     if entry.slack.reply_to_mode is defined %}
{%       set _ = _slack_acct.update({'replyToMode': entry.slack.reply_to_mode}) %}
{%     endif %}
{%     if entry.slack.reply_to_mode_by_chat_type is defined %}
{%       set _ = _slack_acct.update({'replyToModeByChatType': entry.slack.reply_to_mode_by_chat_type}) %}
{%     endif %}
{%     if entry.slack.thread is defined %}
{%       set _ = _slack_acct.update({'thread': entry.slack.thread}) %}
{%     endif %}
{%     if entry.slack.actions is defined %}
{%       set _ = _slack_acct.update({'actions': entry.slack.actions}) %}
{%     endif %}
{%     if entry.slack.exec_approvals is defined %}
{%       set _ = _slack_acct.update({'execApprovals': entry.slack.exec_approvals}) %}
{%     endif %}
{%     if entry.slack.socket_mode is defined %}
{%       set _ = _slack_acct.update({'socketMode': entry.slack.socket_mode}) %}
{%     endif %}
{%     if entry.slack.capabilities is defined %}
{%       set _ = _slack_acct.update({'capabilities': entry.slack.capabilities}) %}
{%     endif %}
{%     set _ = _slack_acct.update({'botToken': _slack_bot_token, 'appToken': _slack_app_token}) %}
{%     if _slack_user_token | default('') != '' %}
{%       set _ = _slack_acct.update({'userToken': _slack_user_token}) %}
{%     endif %}
{%     if _entry_slack_proxy_enabled %}
{%       set _slack_credential_proxy = {
           'enabled': true,
           'botApiUrl': _locksmith_base_url ~ '/transport/' ~ _slack_bot_tool_name ~ '/',
           'appApiUrl': _locksmith_base_url ~ '/transport/' ~ _slack_app_tool_name ~ '/'
         } %}
{%       if _slack_user_token | default('') != '' %}
{%         set _ = _slack_credential_proxy.update({'userApiUrl': _locksmith_base_url ~ '/transport/' ~ _slack_user_tool_name ~ '/'}) %}
{%       endif %}
{%       set _ = _slack_acct.update({'credentialProxy': _slack_credential_proxy}) %}
{%     endif %}
{%     set _ = _slack_accounts.update({entry.agent.id: _slack_acct}) %}
{%   endfor %}
{%   set _ = _channels_out.update({'slack': {'defaultAccount': _slack_default.agent.id, 'accounts': _slack_accounts}}) %}
{% endif %}
{% if _agent_telegram | length > 0 %}
{%   set _tg_default = _agent_telegram | selectattr('agent.default', 'defined') | selectattr('agent.default', 'equalto', true) | first | default(_agent_telegram[0]) %}
{%   set _tg_accounts = {} %}
{%   for entry in _agent_telegram %}
{%     set _tg_acct = {
         'name': entry.agent.name | default(entry.agent.id),
         'botToken': entry.telegram.bot_token,
         'dmPolicy': entry.telegram.dm_policy | default('pairing'),
         'groupPolicy': entry.telegram.group_policy | default('allowlist'),
         'streaming': entry.telegram.streaming | default('partial')
       } %}
{%     if entry.telegram.group_allow_from is defined %}
{%       set _ = _tg_acct.update({'groupAllowFrom': entry.telegram.group_allow_from}) %}
{%     endif %}
{%     set _ = _tg_accounts.update({entry.agent.id: _tg_acct}) %}
{%   endfor %}
{%   set _ = _channels_out.update({'telegram': {'defaultAccount': _tg_default.agent.id, 'accounts': _tg_accounts}}) %}
{% endif %}
{% if _agent_discord | length > 0 %}
{%   set _discord_default = _agent_discord | selectattr('agent.default', 'defined') | selectattr('agent.default', 'equalto', true) | first | default(_agent_discord[0]) %}
{%   set _discord_accounts = {} %}
{%   for entry in _agent_discord %}
{%     set _discord_acct = {
         'name': entry.agent.name | default(entry.agent.id),
         'enabled': true,
         'token': entry.discord.bot_token,
         'dm': {'enabled': entry.discord.dm_enabled | default(false) | bool},
         'guilds': {
           entry.discord.guild_id: {
             'users': entry.discord.allowed_users | default([]),
             'requireMention': entry.discord.require_mention | default(true) | bool
           }
         }
       } %}
{%     set _ = _discord_accounts.update({entry.agent.id: _discord_acct}) %}
{%   endfor %}
{%   set _ = _channels_out.update({'discord': {'defaultAccount': _discord_default.agent.id, 'accounts': _discord_accounts}}) %}
{% endif %}
  "channels": {{ _channels_out | to_nice_json }},
  "gateway": {
    "port": {{ openclaw.gateway_port }},
    "mode": "local",
    "bind": "{{ openclaw.gateway_bind }}",
    "auth": {
      "mode": "{{ openclaw.gateway_auth_mode }}",
      "token": "{{ openclaw_gateway_token }}",
      "password": "{{ openclaw_gateway_password }}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": {{ openclaw.deny_commands | to_json }}
    },
    "controlUi": {
      "enabled": true,
      "root": "/home/openclaw/.openclaw/control-ui",
      "allowedOrigins": {{ openclaw.control_ui_origins | to_json }}
    },
    "tls": {
      "enabled": true
    },
    "http": {
      "securityHeaders": {
        "strictTransportSecurity": "max-age=31536000; includeSubDomains"
      }
    }
  },
{% if telemetry.enabled | default(false) %}
  "diagnostics": {
    "enabled": true,
    "otel": {
      "enabled": true,
      "endpoint": "http://{{ telemetry.host }}:{{ telemetry.otel_collector.http_port }}",
      "serviceName": "openclaw-gateway",
      "traces": true,
      "metrics": true,
      "sampleRate": 1.0,
      "flushIntervalMs": 5000
    }
  },
{% endif %}
{% if _agent_slack | length > 0 or _agent_telegram | length > 0 or _agent_discord | length > 0 or openclaw_bindings | default([]) | length > 0 %}
  "bindings": [
{% set _all_bindings = [] %}
{% for entry in _agent_slack %}
{%   set _ = _all_bindings.append({'agentId': entry.agent.id, 'channel': 'slack', 'accountId': entry.agent.id}) %}
{% endfor %}
{% for entry in _agent_telegram %}
{%   set _ = _all_bindings.append({'agentId': entry.agent.id, 'channel': 'telegram', 'accountId': entry.agent.id}) %}
{% endfor %}
{% for entry in _agent_discord %}
{%   set _ = _all_bindings.append({'agentId': entry.agent.id, 'channel': 'discord', 'accountId': entry.agent.id}) %}
{% endfor %}
{% for binding in openclaw_bindings | default([]) %}
{%   set _ = _all_bindings.append(binding) %}
{% endfor %}
{% for binding in _all_bindings %}
{%   if binding.match is defined %}
    {{ binding | to_nice_json(indent=2) | indent(4, false) }}{{ "," if not loop.last }}
{%   else %}
    {
      "agentId": "{{ binding.agentId }}",
      "match": { "channel": "{{ binding.channel }}", "accountId": "{{ binding.accountId }}" }
    }{{ "," if not loop.last }}
{%   endif %}
{% endfor %}
  ],
{% endif %}
  "plugins": {
{% set _plugin_entries_out = {} %}
{% set _plugin_channels = _chans.keys() | list %}
{% if _agent_slack | length > 0 and 'slack' not in _plugin_channels %}
{%   set _ = _plugin_channels.append('slack') %}
{% endif %}
{% if _agent_telegram | length > 0 and 'telegram' not in _plugin_channels %}
{%   set _ = _plugin_channels.append('telegram') %}
{% endif %}
{% if _agent_discord | length > 0 and 'discord' not in _plugin_channels %}
{%   set _ = _plugin_channels.append('discord') %}
{% endif %}
{% for channel in _plugin_channels %}
{%   set _ = _plugin_entries_out.update({channel: {'enabled': true}}) %}
{% endfor %}
{% if _memory_active.enabled | default(false) %}
{%   set _memory_active_qmd = _memory_active.qmd | default({}) %}
{%   set _memory_active_assoc = _memory_active.associative_recall | default({}) %}
{%   set _active_config = {
       'enabled': true,
       'agents': _memory_active.agents | default([]),
       'allowedChatTypes': _memory_active.allowed_chat_types | default(['direct']),
       'queryMode': _memory_active.query_mode | default('recent'),
       'promptStyle': _memory_active.prompt_style | default('balanced'),
       'timeoutMs': _memory_active.timeout_ms | default(15000),
       'maxSummaryChars': _memory_active.max_summary_chars | default(220),
       'persistTranscripts': _memory_active.persist_transcripts | default(false),
       'logging': _memory_active.logging | default(true),
       'associativeRecall': {
         'enabled': _memory_active_assoc.enabled | default(false),
         'intrusionRate': _memory_active_assoc.intrusion_rate | default(0.07),
         'maxSnippets': _memory_active_assoc.max_snippets | default(1),
         'maxSnippetChars': _memory_active_assoc.max_snippet_chars | default(240),
         'minSignalCount': _memory_active_assoc.min_signal_count | default(1),
         'minScore': _memory_active_assoc.min_score | default(0),
         'maxAgeDays': _memory_active_assoc.max_age_days | default(90),
         'includePromoted': _memory_active_assoc.include_promoted | default(false),
         'includeStructural': _memory_active_assoc.include_structural | default(true),
         'recencyHalfLifeDays': _memory_active_assoc.recency_half_life_days | default(14)
       },
       'qmd': {
         'searchMode': _memory_active_qmd.search_mode | default('inherit')
       }
     } %}
{%   if _memory_active.model | default('') != '' %}
{%     set _ = _active_config.update({'model': _memory_active.model}) %}
{%   endif %}
{%   if _memory_active.model_fallback | default('') != '' %}
{%     set _ = _active_config.update({'modelFallback': _memory_active.model_fallback}) %}
{%   endif %}
{%   if _memory_active.thinking is defined %}
{%     set _ = _active_config.update({'thinking': _memory_active.thinking}) %}
{%   endif %}
{%   if _memory_active.tools_allow is defined %}
{%     set _ = _active_config.update({'toolsAllow': _memory_active.tools_allow}) %}
{%   endif %}
{%   if _memory_active.allowed_chat_ids is defined %}
{%     set _ = _active_config.update({'allowedChatIds': _memory_active.allowed_chat_ids}) %}
{%   endif %}
{%   if _memory_active.denied_chat_ids is defined %}
{%     set _ = _active_config.update({'deniedChatIds': _memory_active.denied_chat_ids}) %}
{%   endif %}
{%   set _ = _plugin_entries_out.update({'active-memory': {'enabled': true, 'config': _active_config}}) %}
{% endif %}
{% if _memory_dreaming.enabled | default(false) %}
{%   set _dream_light = _memory_dreaming.light | default({}) %}
{%   set _dream_rem = _memory_dreaming.rem | default({}) %}
{%   set _dream_deep = _memory_dreaming.deep | default({}) %}
{%   set _dream_deep_config = {
       'enabled': _dream_deep.enabled | default(true),
       'promotionTargetPath': _dream_deep.promotion_target_path | default('memory/promoted.md'),
       'limit': _dream_deep.limit | default(10),
       'minScore': _dream_deep.min_score | default(0.8),
       'minRecallCount': _dream_deep.min_recall_count | default(3),
       'minUniqueQueries': _dream_deep.min_unique_queries | default(3),
       'maxPromotedSnippetTokens': _dream_deep.max_promoted_snippet_tokens | default(160)
     } %}
{%   if _dream_deep.max_age_days is defined %}
{%     set _ = _dream_deep_config.update({'maxAgeDays': _dream_deep.max_age_days}) %}
{%   endif %}
{%   set _dream_config = {
       'enabled': true,
       'frequency': _memory_dreaming.frequency | default('0 3 * * *'),
       'verboseLogging': _memory_dreaming.verbose_logging | default(false),
       'phases': {
         'light': {
           'enabled': _dream_light.enabled | default(true)
         },
         'rem': {
           'enabled': _dream_rem.enabled | default(true)
         },
         'deep': _dream_deep_config
       }
     } %}
{%   if _memory_dreaming.timezone | default('') != '' %}
{%     set _ = _dream_config.update({'timezone': _memory_dreaming.timezone}) %}
{%   endif %}
{%   if _memory_dreaming.model | default('') != '' %}
{%     set _ = _dream_config.update({'model': _memory_dreaming.model}) %}
{%   endif %}
{%   set _ = _plugin_entries_out.update({'memory-core': {'enabled': true, 'config': {'dreaming': _dream_config}}}) %}
{% endif %}
{% if locksmith.enabled | default(true) %}
{%   set _locksmith_projected_tools = {} %}
{%   for tool in locksmith.tools | default([]) %}
{%     if tool.projected | default(true) and (tool.api_key | default('') != '' or tool.api_key_from_env | default(false) or tool.auth_required | default(true) == false) %}
{%       set _tool_config = {'enabled': true, 'description': tool.description | default(tool.name)} %}
{%       if tool.label is defined %}
{%         set _ = _tool_config.update({'label': tool.label}) %}
{%       endif %}
{%       if tool.mode is defined %}
{%         set _ = _tool_config.update({'mode': tool.mode}) %}
{%       endif %}
{%       if tool.method is defined %}
{%         set _ = _tool_config.update({'method': tool.method}) %}
{%       endif %}
{%       if tool.path is defined %}
{%         set _ = _tool_config.update({'path': tool.path}) %}
{%       endif %}
{%       if tool.parameters is defined %}
{%         set _ = _tool_config.update({'parameters': tool.parameters}) %}
{%       endif %}
{%       set _ = _locksmith_projected_tools.update({tool.name: _tool_config}) %}
{%     endif %}
{%   endfor %}
{%   for tool in locksmith.kamiwaza.projected_tools | default([]) %}
{%     if tool.enabled | default(true) and tool.slug | default('') != '' %}
{%       set _tool_config = {
           'enabled': true,
           'description': tool.description | default(tool.slug),
           'mode': tool.mode | default('json')
         } %}
{%       if tool.label is defined %}
{%         set _ = _tool_config.update({'label': tool.label}) %}
{%       endif %}
{%       if tool.method is defined %}
{%         set _ = _tool_config.update({'method': tool.method}) %}
{%       endif %}
{%       if tool.path is defined %}
{%         set _ = _tool_config.update({'path': tool.path}) %}
{%       endif %}
{%       if tool.parameters is defined %}
{%         set _ = _tool_config.update({'parameters': tool.parameters}) %}
{%       endif %}
{%       set _ = _locksmith_projected_tools.update({tool.slug: _tool_config}) %}
{%     endif %}
{%   endfor %}
{%   set _locksmith_base_url = locksmith.openclaw_base_url | default('') %}
{%   if _locksmith_base_url == '' %}
{%     set _locksmith_base_url = 'http://' ~ (locksmith.listen_host | default('127.0.0.1')) ~ ':' ~ (locksmith.listen_port | default(9200)) %}
{%   endif %}
{%   set _locksmith_config = {
       'required': locksmith.required | default(true),
       'genericTool': locksmith.generic_tool | default(false),
       'baseUrl': _locksmith_base_url,
       'catalogTtlSeconds': locksmith.catalog_ttl_seconds | default(30),
       'timeoutSeconds': locksmith.timeout_seconds | default(30),
       'maxResponseBytes': locksmith.max_response_bytes | default(262144),
       'promptCatalog': locksmith.prompt_catalog | default(true),
       'tools': _locksmith_projected_tools
     } %}
{%   if locksmith.inbound_token | default('') != '' %}
{%     set _ = _locksmith_config.update({'inboundToken': {'ref': 'env:LOCKSMITH_INBOUND_TOKEN'}}) %}
{%   endif %}
{%   set _ = _plugin_entries_out.update({'locksmith': {'enabled': true, 'config': _locksmith_config}}) %}
{% endif %}
    "entries": {{ _plugin_entries_out | to_nice_json(indent=2) | indent(6, false) }}
  }
}
