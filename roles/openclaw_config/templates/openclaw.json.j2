{# Filter endpoints: LAN always active, cloud only if key is configured #}
{% set _eps = [] %}
{% for ep in inference.endpoints %}
{%   if ep.api_key | default('not-required') != '' %}
{%     set _ = _eps.append(ep) %}
{%   endif %}
{% endfor %}
{# ── Agent-scoped channel accounts ───────────────────────────────── #}
{# Collect agents that define their own Slack or Telegram identity.   #}
{# Each entry: {agent: <agent dict>, slack: <merged>, telegram: <merged>} #}
{% set _agent_slack = [] %}
{% set _agent_telegram = [] %}
{% set _agent_discord = [] %}
{% for agent in openclaw_agents | default([]) %}
{%   if agent.slack is defined and agent.slack.bot_token | default('') != '' %}
{%     set _slack = _agent_slack_defaults | default({}) | combine(agent.slack, recursive=True) %}
{%     set _ = _agent_slack.append({'agent': agent, 'slack': _slack}) %}
{%   endif %}
{%   if agent.telegram is defined and agent.telegram.bot_token | default('') != '' %}
{%     set _tg = _agent_telegram_defaults | default({}) | combine(agent.telegram, recursive=True) %}
{%     set _ = _agent_telegram.append({'agent': agent, 'telegram': _tg}) %}
{%   endif %}
{%   if agent.discord is defined and agent.discord.bot_token | default('') != '' %}
{%     set _ = _agent_discord.append({'agent': agent, 'discord': agent.discord}) %}
{%   endif %}
{% endfor %}
{# ── Legacy channels (non-agent-scoped, or fallback when no agent defines it) #}
{% set _chans = {} %}
{% for name, cfg in (openclaw_channels | default({})).items() %}
{%   if name == 'slack' and _agent_slack | length > 0 %}
{#     Skip legacy slack — agents own it now #}
{%   elif name == 'telegram' and _agent_telegram | length > 0 %}
{#     Skip legacy telegram — agents own it now #}
{%   elif cfg.botToken | default('') != '' %}
{%     set _ = _chans.update({name: cfg}) %}
{%   endif %}
{% endfor %}
{# ── Resolve default agent (for workspace path) ─────────────────── #}
{% set _default_agent = openclaw_agents | default([]) | selectattr('default', 'defined') | selectattr('default', 'equalto', true) | first | default(openclaw_agents | default([]) | first | default(none)) %}
{
  "meta": {
    "lastTouchedVersion": "ansible-managed",
    "lastTouchedAt": "{{ ansible_facts['date_time']['iso8601'] }}"
  },
  "models": {
    "mode": "merge",
    "providers": {
{% for ep in _eps %}
      "{{ ep.provider_name }}": {
{% if llamafirewall.enabled | default(false) %}
        "baseUrl": "http://{{ llamafirewall.connect_host | default(llamafirewall.listen_host) }}:{{ llamafirewall.listen_port }}/{{ ep.provider_name }}/v1",
{% else %}
        "baseUrl": "{{ ep.base_url }}",
{% endif %}
{% if llamafirewall.enabled | default(false) %}
        "apiKey": "not-required",
{% else %}
        "apiKey": "{{ ep.api_key | default('not-required') }}",
{% endif %}
        "api": "{{ ep.api_type }}",
        "models": [
          {
            "id": "{{ ep.model_id }}",
            "name": "{{ ep.model_name }}",
            "reasoning": {{ ep.reasoning | to_json }},
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": {{ ep.context_window }},
            "maxTokens": {{ ep.max_tokens }}
          }
        ]
      }{{ "," if not loop.last }}
{% endfor %}
    }
  },
  "agents": {
    "defaults": {
{% set primary = _eps | selectattr('primary', 'equalto', true) | first %}
      "model": {
        "primary": "{{ primary.provider_name }}/{{ primary.model_id }}"
      },
      "models": {
{% for ep in _eps %}
        "{{ ep.provider_name }}/{{ ep.model_id }}": {
          "alias": "{{ ep.model_id | lower | replace('_','-') | replace('/','-') }}"
{% if ep.params is defined %}
          ,"params": {{ ep.params | to_json }}
{% endif %}
        }{{ "," if not loop.last }}
{% endfor %}
      },
      "workspace": "{{ openclaw_data_dir | default('/home/openclaw/.openclaw') }}/{% if _default_agent %}agents/{{ _default_agent.workspace_subdir | default(_default_agent.id) }}/workspace{% else %}workspace{% endif %}",
      "compaction": {
        "mode": "{{ openclaw.compaction_mode }}"
      },
      "maxConcurrent": {{ openclaw.max_concurrent }},
      "subagents": {
        "maxConcurrent": {{ openclaw.subagent_max_concurrent }}
      },
      "sandbox": {
        "mode": "{{ openclaw.sandbox.mode }}",
        "docker": {
          "network": "{{ openclaw.sandbox.docker_network }}",
          "readOnlyRoot": {{ openclaw.sandbox.read_only_root | to_json }},
          "memory": "{{ openclaw.sandbox.memory }}",
          "cpus": {{ openclaw.sandbox.cpus }},
          "pidsLimit": {{ openclaw.sandbox.pids_limit }}
        }
      }
    }{% if openclaw_agents | default([]) | length > 0 %},
    "list": [
{% for agent in openclaw_agents %}
      {
        "id": "{{ agent.id }}",
        "name": "{{ agent.name | default(agent.id) }}",
{% if agent.default | default(false) %}
        "default": true,
{% endif %}
        "workspace": "{{ openclaw_data_dir | default('/home/openclaw/.openclaw') }}/agents/{{ agent.workspace_subdir | default(agent.id) }}/workspace",
{% if agent.skills is defined %}
        "skills": {{ agent.skills | to_json }},
{% endif %}
        "memorySearch": {
          "enabled": {{ agent.memory_search | default(false) | to_json }},
          "sources": ["memory", "sessions"],
          "extraPaths": [
            "{{ openclaw_data_dir | default('/home/openclaw/.openclaw') }}/shared"
          ]{% if ollama.enabled | default(false) and agent.memory_search | default(false) %},
          "provider": "ollama",
          "remote": {
            "baseUrl": "http://{{ ollama.host | default('127.0.0.1') }}:{{ ollama.port | default(11434) }}"
          }{% endif %}
        }
{% if agent.tools is defined %}
        ,"tools": {{ agent.tools | to_nice_json(indent=2) }}
{% endif %}
{% if agent.subagents is defined %}
        ,"subagents": {{ agent.subagents | to_nice_json(indent=2) }}
{% endif %}
{% if agent.sandbox is defined %}
        ,"sandbox": {{ agent.sandbox | to_nice_json(indent=2) }}
{% endif %}
      }{{ "," if not loop.last }}
{% endfor %}
    ]
{% endif %}
  },
  "tools": {
    "profile": "{{ openclaw.tools_profile }}"
  },
  "env": {
    "HTTP_PROXY": "{{ openclaw.fetch_proxy }}",
    "HTTPS_PROXY": "{{ openclaw.fetch_proxy }}",
    "NO_PROXY": "localhost,127.0.0.1,172.17.0.1,{{ network.allowed_lan_ips | map(attribute='ip') | join(',') }}{% if openclaw.no_proxy_extra is defined %},{{ openclaw.no_proxy_extra | join(',') }}{% endif %}"
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
{# Build channels dict: start with legacy channels, add agent-scoped Slack/Telegram #}
{% set _channels_out = {} %}
{% for name, cfg in _chans.items() %}
{%   set _ = _channels_out.update({name: cfg}) %}
{% endfor %}
{% if _agent_slack | length > 0 %}
{%   set _slack_default = _agent_slack | selectattr('agent.default', 'defined') | selectattr('agent.default', 'equalto', true) | first | default(_agent_slack[0]) %}
{%   set _slack_accounts = {} %}
{%   for entry in _agent_slack %}
{%     set _slack_acct = {
         'name': entry.agent.name | default(entry.agent.id),
         'mode': entry.slack.mode | default('socket'),
         'botToken': entry.slack.bot_token,
         'appToken': entry.slack.app_token | default(''),
         'groupPolicy': entry.slack.group_policy | default('allowlist'),
         'streaming': entry.slack.streaming | default('partial')
       } %}
{%     set _ = _slack_accounts.update({entry.agent.id: _slack_acct}) %}
{%   endfor %}
{%   set _ = _channels_out.update({'slack': {'defaultAccount': _slack_default.agent.id, 'accounts': _slack_accounts}}) %}
{% endif %}
{% if _agent_telegram | length > 0 %}
{%   set _tg_default = _agent_telegram | selectattr('agent.default', 'defined') | selectattr('agent.default', 'equalto', true) | first | default(_agent_telegram[0]) %}
{%   set _tg_accounts = {} %}
{%   for entry in _agent_telegram %}
{%     set _tg_acct = {
         'name': entry.agent.name | default(entry.agent.id),
         'botToken': entry.telegram.bot_token,
         'dmPolicy': entry.telegram.dm_policy | default('pairing'),
         'groupPolicy': entry.telegram.group_policy | default('allowlist'),
         'streaming': entry.telegram.streaming | default('partial')
       } %}
{%     if entry.telegram.group_allow_from is defined %}
{%       set _ = _tg_acct.update({'groupAllowFrom': entry.telegram.group_allow_from}) %}
{%     endif %}
{%     set _ = _tg_accounts.update({entry.agent.id: _tg_acct}) %}
{%   endfor %}
{%   set _ = _channels_out.update({'telegram': {'defaultAccount': _tg_default.agent.id, 'accounts': _tg_accounts}}) %}
{% endif %}
{% if _agent_discord | length > 0 %}
{%   set _discord_default = _agent_discord | selectattr('agent.default', 'defined') | selectattr('agent.default', 'equalto', true) | first | default(_agent_discord[0]) %}
{%   set _discord_accounts = {} %}
{%   for entry in _agent_discord %}
{%     set _discord_acct = {
         'name': entry.agent.name | default(entry.agent.id),
         'enabled': true,
         'token': entry.discord.bot_token,
         'dm': {'enabled': entry.discord.dm_enabled | default(false) | bool},
         'guilds': {
           entry.discord.guild_id: {
             'users': entry.discord.allowed_users | default([]),
             'requireMention': entry.discord.require_mention | default(true) | bool
           }
         }
       } %}
{%     set _ = _discord_accounts.update({entry.agent.id: _discord_acct}) %}
{%   endfor %}
{%   set _ = _channels_out.update({'discord': {'defaultAccount': _discord_default.agent.id, 'accounts': _discord_accounts}}) %}
{% endif %}
  "channels": {{ _channels_out | to_nice_json }},
  "gateway": {
    "port": {{ openclaw.gateway_port }},
    "mode": "local",
    "bind": "{{ openclaw.gateway_bind }}",
    "auth": {
      "mode": "{{ openclaw.gateway_auth_mode }}",
      "token": "{{ openclaw_gateway_token }}",
      "password": "{{ openclaw_gateway_password }}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": {{ openclaw.deny_commands | to_json }}
    },
    "controlUi": {
      "enabled": true,
      "root": "/home/openclaw/.openclaw/control-ui",
      "allowedOrigins": {{ openclaw.control_ui_origins | to_json }}
    },
    "tls": {
      "enabled": true
    },
    "http": {
      "securityHeaders": {
        "strictTransportSecurity": "max-age=31536000; includeSubDomains"
      }
    }
  },
{% if telemetry.enabled | default(false) %}
  "diagnostics": {
    "enabled": true,
    "otel": {
      "enabled": true,
      "endpoint": "http://{{ telemetry.host }}:{{ telemetry.otel_collector.http_port }}",
      "serviceName": "openclaw-gateway",
      "traces": true,
      "metrics": true,
      "sampleRate": 1.0,
      "flushIntervalMs": 5000
    }
  },
{% endif %}
{% if _agent_slack | length > 0 or _agent_telegram | length > 0 or _agent_discord | length > 0 %}
  "bindings": [
{% set _all_bindings = [] %}
{% for entry in _agent_slack %}
{%   set _ = _all_bindings.append({'agentId': entry.agent.id, 'channel': 'slack', 'accountId': entry.agent.id}) %}
{% endfor %}
{% for entry in _agent_telegram %}
{%   set _ = _all_bindings.append({'agentId': entry.agent.id, 'channel': 'telegram', 'accountId': entry.agent.id}) %}
{% endfor %}
{% for entry in _agent_discord %}
{%   set _ = _all_bindings.append({'agentId': entry.agent.id, 'channel': 'discord', 'accountId': entry.agent.id}) %}
{% endfor %}
{% for binding in _all_bindings %}
    {
      "agentId": "{{ binding.agentId }}",
      "match": { "channel": "{{ binding.channel }}", "accountId": "{{ binding.accountId }}" }
    }{{ "," if not loop.last }}
{% endfor %}
  ],
{% endif %}
  "plugins": {
{% set _plugin_entries_out = {} %}
{% set _plugin_channels = _chans.keys() | list %}
{% if _agent_slack | length > 0 and 'slack' not in _plugin_channels %}
{%   set _ = _plugin_channels.append('slack') %}
{% endif %}
{% if _agent_telegram | length > 0 and 'telegram' not in _plugin_channels %}
{%   set _ = _plugin_channels.append('telegram') %}
{% endif %}
{% if _agent_discord | length > 0 and 'discord' not in _plugin_channels %}
{%   set _ = _plugin_channels.append('discord') %}
{% endif %}
{% for channel in _plugin_channels %}
{%   set _ = _plugin_entries_out.update({channel: {'enabled': true}}) %}
{% endfor %}
{% if locksmith.enabled | default(false) %}
{%   set _locksmith_projected_tools = {} %}
{%   for tool in locksmith.tools | default([]) %}
{%     if tool.projected | default(true) and (tool.api_key | default('') != '' or tool.auth_required | default(true) == false) %}
{%       set _tool_config = {'enabled': true, 'description': tool.description | default(tool.name)} %}
{%       if tool.label is defined %}
{%         set _ = _tool_config.update({'label': tool.label}) %}
{%       endif %}
{%       set _ = _locksmith_projected_tools.update({tool.name: _tool_config}) %}
{%     endif %}
{%   endfor %}
{%   set _locksmith_base_url = locksmith.openclaw_base_url | default('') %}
{%   if _locksmith_base_url == '' %}
{%     set _locksmith_base_url = 'http://' ~ (locksmith.listen_host | default('127.0.0.1')) ~ ':' ~ (locksmith.listen_port | default(9200)) %}
{%   endif %}
{%   set _locksmith_config = {
       'required': locksmith.required | default(true),
       'genericTool': locksmith.generic_tool | default(false),
       'baseUrl': _locksmith_base_url,
       'catalogTtlSeconds': locksmith.catalog_ttl_seconds | default(30),
       'timeoutSeconds': locksmith.timeout_seconds | default(30),
       'maxResponseBytes': locksmith.max_response_bytes | default(262144),
       'promptCatalog': locksmith.prompt_catalog | default(true),
       'tools': _locksmith_projected_tools
     } %}
{%   if locksmith.inbound_token | default('') != '' %}
{%     set _ = _locksmith_config.update({'inboundToken': {'ref': 'env:LOCKSMITH_INBOUND_TOKEN'}}) %}
{%   endif %}
{%   set _ = _plugin_entries_out.update({'locksmith': {'enabled': true, 'config': _locksmith_config}}) %}
{% endif %}
    "entries": {{ _plugin_entries_out | to_nice_json(indent=2) | indent(6, false) }}
  }
}
