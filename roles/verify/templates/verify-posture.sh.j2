#!/usr/bin/env bash
# Generated by openclaw-deploy ansible for {{ inventory_hostname }}
set -uo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'
CYAN='\033[0;36m'; NC='\033[0m'
PASS=0; FAIL=0

check() {
    local name="$1" cmd="$2"
    if eval "$cmd" >/dev/null 2>&1; then
        echo -e "  ${GREEN}PASS${NC}  $name"
        ((PASS++))
    else
        echo -e "  ${RED}FAIL${NC}  $name"
        ((FAIL++))
    fi
}

echo ""
echo "═══════════════════════════════════════════════════════"
echo "  Security Posture — {{ inventory_hostname }} ({{ host_ip }})"
echo "═══════════════════════════════════════════════════════"

echo ""
echo -e "${CYAN}Phase 1: openclaw-ansible${NC}"
check "openclaw user exists"              "id openclaw"
check "openclaw home dir"                 "test -d /home/openclaw/.openclaw"
check "Docker installed"                  "command -v docker"
check "Docker running"                    "systemctl is-active docker"
check "DOCKER-USER iptables chain"        "iptables -L DOCKER-USER -n"
check "fail2ban active"                   "systemctl is-active fail2ban"

echo ""
echo -e "${CYAN}Phase 2: Hardening${NC}"
check "runsc binary exists"              "command -v runsc"
check "Docker default runtime = runsc"   "docker info 2>/dev/null | grep -q 'Default Runtime: runsc'"
check "no-new-privileges in daemon.json" "grep -q 'no-new-privileges.*true' /etc/docker/daemon.json"
check "gVisor functional"                "docker run --rm ubuntu:24.04 dmesg 2>&1 | grep -q 'Starting gVisor'"

check "pipelock binary exists"           "test -x /usr/local/bin/pipelock"
check "pipelock user exists"             "id pipelock"
check "pipelock service running"         "systemctl is-active pipelock"
check "pipelock listening on :{{ pipelock.listen.split(':')[1] }}"  "ss -tlnp | grep -q ':{{ pipelock.listen.split(':')[1] }}'"
check "pipelock config exists"           "test -f /etc/pipelock/pipelock.yaml"

check "UFW disabled"                     "! systemctl is-active ufw"
check "nftables table inet openclaw"     "nft list tables | grep -q 'inet openclaw'"
check "nftables skuid egress rule"       "nft list chain inet openclaw output 2>/dev/null | grep -q 'skuid'"
check "nftables allowed_lan_ips set"     "nft list set inet openclaw allowed_lan_ips 2>/dev/null | grep -q '{{ network.gateway_ip }}'"
check "nftables output hook loaded"      "nft list ruleset 2>/dev/null | grep -q 'chain output'"
check "Docker tables still intact"       "iptables -L DOCKER-USER -n"

check "egress blocked (openclaw user)"   "! sudo -u openclaw curl -sf --max-time 3 https://httpbin.org/ip"
check "egress blocked (root)"            "! curl -sf --max-time 3 https://httpbin.org/ip"
check "egress works via pipelock (fetch)" "curl -sf --max-time 5 'http://{{ pipelock.listen }}/fetch?url=https://api.anthropic.com'"
check "egress works via pipelock (CONNECT)" "curl -sf --proxy http://{{ pipelock.listen }} --max-time 5 https://api.telegram.org/"
check "docker pull via pipelock"         "sudo docker pull --quiet debian:bookworm-slim"

{% if locksmith.enabled | default(false) %}
{% set locksmith_base = "http://" ~ locksmith.listen_host | default('127.0.0.1') ~ ":" ~ locksmith.listen_port | default(9200) %}
echo ""
echo -e "${CYAN}Agent Locksmith${NC}"
check "locksmith service running"              "systemctl is-active locksmith"
check "locksmith listening on :{{ locksmith.listen_port | default(9200) }}"  "ss -tlnp | grep -q ':{{ locksmith.listen_port | default(9200) }}'"
check "locksmith health endpoint"              "curl -sf --max-time 3 {{ locksmith_base }}/health"
{% if locksmith.inbound_token | default('') != '' %}
check "locksmith rejects unauthenticated"      "curl -s -o /dev/null -w '%{http_code}' --max-time 3 {{ locksmith_base }}/tools | grep -q '^401$'"
check "locksmith tool discovery (authed)"      "curl -sf --max-time 3 -H 'Authorization: Bearer {{ locksmith.inbound_token }}' {{ locksmith_base }}/tools | grep -q 'tools'"
{% else %}
check "locksmith tool discovery"              "curl -sf --max-time 3 {{ locksmith_base }}/tools | grep -q 'tools'"
{% endif %}
{% for tool in locksmith.tools %}
{%   if tool.api_key | default('') != '' %}
{%     if locksmith.inbound_token | default('') != '' %}
check "locksmith proxies: {{ tool.name }}" "curl -sf --max-time 10 -H 'Authorization: Bearer {{ locksmith.inbound_token }}' {{ locksmith_base }}/tools | grep -q '{{ tool.name }}'"
{%     else %}
check "locksmith proxies: {{ tool.name }}" "curl -sf --max-time 10 {{ locksmith_base }}/tools | grep -q '{{ tool.name }}'"
{%     endif %}
{%   endif %}
{% endfor %}
{% endif %}

{% if llamafirewall.enabled | default(false) %}
echo ""
echo -e "${CYAN}LlamaFirewall${NC}"
check "llamafirewall service running"    "systemctl is-active llamafirewall"
check "llamafirewall listening on :{{ llamafirewall.listen_port }}"  "ss -tlnp | grep -q ':{{ llamafirewall.listen_port }}'"
check "llamafirewall health endpoint"    "curl -sf --max-time 3 http://{{ llamafirewall.listen_host }}:{{ llamafirewall.listen_port }}/health"
{% for ep in inference.endpoints %}
{%   if ep.location | default('local') != 'cloud' and ep.api_key | default('not-required') not in ['CHANGE_ME', ''] %}
check "llamafirewall route: {{ ep.provider_name }}"  "curl -sf --max-time 3 http://{{ llamafirewall.listen_host }}:{{ llamafirewall.listen_port }}/{{ ep.provider_name }}/models"
{%   endif %}
{% endfor %}
{% endif %}

echo ""
echo -e "${CYAN}Phase 3: OpenClaw${NC}"
check "openclaw CLI installed"           "test -x {{ final_openclaw_binary | default(openclaw_binary) }}"
check "openclaw service running"         "systemctl is-active openclaw"
{% if openclaw.gateway_bind == "loopback" %}
check "gateway on loopback :{{ openclaw.gateway_port }}"  "ss -tlnp | grep ':{{ openclaw.gateway_port }}' | grep -q '127.0.0.1'"
{% else %}
check "gateway listening on :{{ openclaw.gateway_port }}"  "ss -tlnp | grep -q ':{{ openclaw.gateway_port }}'"
{% endif %}
check "openclaw.json exists"             "test -f /home/openclaw/.openclaw/openclaw.json"

echo ""
echo -e "${CYAN}Infrastructure${NC}"
check "DNS via OPNsense"                 "dig +short @{{ network.gateway_ip }} api.anthropic.com | grep -q '[0-9]'"
{% for ep in verify.inference_endpoints %}
{%   if ep.requires_key | default('') == '' or lookup('vars', ep.requires_key, default='CHANGE_ME') != '' %}
{%     if ep.cloud | default(false) %}
check "inference: {{ ep.name }}"         "curl -s -o /dev/null -w '%{http_code}' --proxy http://{{ pipelock.listen }} --max-time 5 {{ ep.url }} | grep -qvE '^000$'"
{%     else %}
check "inference: {{ ep.name }}"         "sudo -u llamafirewall curl -s{{ 'k' if ep.skip_tls | default(false) }}f --max-time 3 {{ ep.url }}"
{%     endif %}
{%   endif %}
{% endfor %}

echo ""
echo "═══════════════════════════════════════════════════════"
printf "  ${GREEN}PASS: %-4d${NC} ${RED}FAIL: %-4d${NC}\n" $PASS $FAIL
if [[ $FAIL -eq 0 ]]; then
    echo -e "  ${GREEN}COMPLIANT${NC}"
else
    echo -e "  ${RED}NON-COMPLIANT ($FAIL failures)${NC}"
fi
echo "═══════════════════════════════════════════════════════"
