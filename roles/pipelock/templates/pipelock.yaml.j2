# Generated by openclaw-deploy ansible
version: 1
mode: {{ pipelock.mode }}
enforce: {{ pipelock.enforce | to_json }}

api_allowlist:
{% for domain in pipelock.api_allowlist + pipelock.api_allowlist_extra | default([]) %}
  - "{{ domain }}"
{% endfor %}

fetch_proxy:
  listen: "{{ pipelock.listen }}"
  timeout_seconds: 30
  max_response_mb: 10

forward_proxy:
  enabled: true
  max_tunnel_seconds: 300
  idle_timeout_seconds: 120
  sni_verification: true

monitoring:
  entropy_threshold: {{ pipelock.monitoring.entropy_threshold }}
  max_url_length: {{ pipelock.monitoring.max_url_length }}
  max_requests_per_minute: {{ pipelock.monitoring.max_requests_per_minute }}

blocklist:
{% for domain in pipelock.blocklist %}
  - "{{ domain }}"
{% endfor %}

dlp:
  scan_env: {{ pipelock.dlp.scan_env | to_json }}
  secret_patterns: {{ pipelock.dlp.secret_patterns | to_json }}
  entropy_analysis: {{ pipelock.dlp.entropy_analysis | to_json }}

tool_chain_detection:
  enabled: {{ pipelock.tool_chain_detection.enabled | to_json }}
  action: {{ pipelock.tool_chain_detection.action }}
  window_size: {{ pipelock.tool_chain_detection.window_size }}
  window_seconds: {{ pipelock.tool_chain_detection.window_seconds }}
  max_gap: {{ pipelock.tool_chain_detection.max_gap }}
