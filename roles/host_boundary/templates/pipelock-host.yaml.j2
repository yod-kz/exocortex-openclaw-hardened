# Generated by openclaw-hardened host_boundary role
version: 1
mode: {{ host_boundary_effective.pipelock.mode | default(pipelock.mode | default('balanced')) }}
enforce: {{ host_boundary_effective.pipelock.enforce | default(pipelock.enforce | default(true)) | to_json }}

api_allowlist:
{% set _api_allowlist = (host_boundary_effective.pipelock.api_allowlist | default(pipelock.api_allowlist | default([]))) + (host_boundary_effective.pipelock.api_allowlist_extra | default(pipelock.api_allowlist_extra | default([]))) %}
{% for domain in _api_allowlist %}
  - "{{ domain }}"
{% endfor %}

fetch_proxy:
  listen: "{{ host_boundary_effective.pipelock.listen }}"
  timeout_seconds: {{ host_boundary_effective.pipelock.timeout_seconds | default(30) }}
  max_response_mb: {{ host_boundary_effective.pipelock.max_response_mb | default(10) }}

forward_proxy:
  enabled: true
  max_tunnel_seconds: {{ host_boundary_effective.pipelock.max_tunnel_seconds | default(300) }}
  idle_timeout_seconds: {{ host_boundary_effective.pipelock.idle_timeout_seconds | default(120) }}
  sni_verification: {{ host_boundary_effective.pipelock.forward_proxy.sni_verification | default(pipelock.forward_proxy.sni_verification | default(true)) | to_json }}

monitoring:
  entropy_threshold: {{ host_boundary_effective.pipelock.monitoring.entropy_threshold | default(pipelock.monitoring.entropy_threshold | default(4.5)) }}
  max_url_length: {{ host_boundary_effective.pipelock.monitoring.max_url_length | default(pipelock.monitoring.max_url_length | default(2048)) }}
  max_requests_per_minute: {{ host_boundary_effective.pipelock.monitoring.max_requests_per_minute | default(pipelock.monitoring.max_requests_per_minute | default(60)) }}

blocklist:
{% set _blocklist = host_boundary_effective.pipelock.blocklist | default(pipelock.blocklist | default([])) %}
{% for domain in _blocklist %}
  - "{{ domain }}"
{% endfor %}

dlp:
  scan_env: {{ host_boundary_effective.pipelock.dlp.scan_env | default(pipelock.dlp.scan_env | default(false)) | to_json }}
  secret_patterns: {{ host_boundary_effective.pipelock.dlp.secret_patterns | default(pipelock.dlp.secret_patterns | default(true)) | to_json }}
  entropy_analysis: {{ host_boundary_effective.pipelock.dlp.entropy_analysis | default(pipelock.dlp.entropy_analysis | default(true)) | to_json }}

tool_chain_detection:
  enabled: {{ host_boundary_effective.pipelock.tool_chain_detection.enabled | default(pipelock.tool_chain_detection.enabled | default(true)) | to_json }}
  action: {{ host_boundary_effective.pipelock.tool_chain_detection.action | default(pipelock.tool_chain_detection.action | default('warn')) }}
  window_size: {{ host_boundary_effective.pipelock.tool_chain_detection.window_size | default(pipelock.tool_chain_detection.window_size | default(20)) }}
  window_seconds: {{ host_boundary_effective.pipelock.tool_chain_detection.window_seconds | default(pipelock.tool_chain_detection.window_seconds | default(300)) }}
  max_gap: {{ host_boundary_effective.pipelock.tool_chain_detection.max_gap | default(pipelock.tool_chain_detection.max_gap | default(3)) }}
