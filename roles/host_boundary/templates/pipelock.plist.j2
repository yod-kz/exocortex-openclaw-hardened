<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>{{ host_boundary_effective.pipelock.label }}</string>
  <key>ProgramArguments</key>
  <array>
    <string>{{ host_boundary_effective.pipelock.binary_path }}</string>
    <string>run</string>
    <string>--config</string>
    <string>{{ host_boundary_effective.pipelock.config_path }}</string>
  </array>
{% if host_boundary_effective.pipelock.user | default('') != '' %}
  <key>UserName</key>
  <string>{{ host_boundary_effective.pipelock.user }}</string>
{% endif %}
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>{{ host_boundary_effective.log_dir }}/pipelock.out.log</string>
  <key>StandardErrorPath</key>
  <string>{{ host_boundary_effective.log_dir }}/pipelock.err.log</string>
  <key>WorkingDirectory</key>
  <string>{{ host_boundary_effective.config_dir }}</string>
</dict>
</plist>
