# Generated by openclaw-hardened host_boundary role.
# The host owns this boundary. Guest proxy environment variables are convenience
# only; these PF rules are the enforcement layer.

openclaw_gateway = "{{ host_boundary_gateway_ip }}"
openclaw_untrusted = "{{ host_boundary_untrusted_ip }}"
openclaw_untrusted_gateway = "{{ host_boundary_untrusted_default_gateway | default('255.255.255.255') }}"
openclaw_pipelock_port = "{{ host_boundary_pipelock_port }}"
{% if host_boundary_effective.locksmith.enabled | default(true) %}
openclaw_locksmith_port = "{{ host_boundary_locksmith_port }}"
{% endif %}
{% if host_boundary_effective.pf.gateway_api_host_ports | default([]) | length > 0 %}
openclaw_gateway_api_ports = "{ {{ host_boundary_effective.pf.gateway_api_host_ports | join(', ') }} }"
{% endif %}
{% if host_boundary_task_transport_ports | default([]) | length > 0 %}
openclaw_task_transport_ports = "{ {{ host_boundary_task_transport_ports | join(', ') }} }"
{% endif %}

pass quick on lo0 all

# DHCP needed by Lima/VZ guests during network churn.
pass quick proto udp from { $openclaw_gateway, $openclaw_untrusted } port 68 to 255.255.255.255 port 67 keep state
pass quick proto udp from { $openclaw_gateway, $openclaw_untrusted } port 68 to $openclaw_untrusted_gateway port 67 keep state

# Host Pipelock is reachable from gateway and untrusted. Pipelock policy then
# decides what public egress is allowed.
pass quick proto tcp from 127.0.0.1 to any port $openclaw_pipelock_port keep state
pass quick proto tcp from $openclaw_gateway to any port $openclaw_pipelock_port keep state
pass quick proto tcp from $openclaw_untrusted to any port $openclaw_pipelock_port keep state

{% if host_boundary_effective.locksmith.enabled | default(true) %}
# Host Locksmith is reachable only from the trusted gateway.
pass quick proto tcp from 127.0.0.1 to any port $openclaw_locksmith_port keep state
pass quick proto tcp from $openclaw_gateway to any port $openclaw_locksmith_port keep state
block drop quick proto tcp from $openclaw_untrusted to any port $openclaw_locksmith_port label "openclaw-untrusted-locksmith-block"
{% endif %}

{% if host_boundary_task_transport_ports | default([]) | length > 0 %}
# Optional host-forwarded task transport, usually gateway -> untrusted SSH.
pass quick proto tcp from $openclaw_gateway to any port $openclaw_task_transport_ports keep state
{% endif %}

{% if host_boundary_effective.pf.gateway_api_host_ports | default([]) | length > 0 %}
# Untrusted must not reach gateway/control API host forwards.
block drop quick proto tcp from $openclaw_untrusted to any port $openclaw_gateway_api_ports label "openclaw-untrusted-gateway-api-block"
{% endif %}

# Host service ports are not LAN services. Earlier pass rules admit loopback and
# the specific VM sources; all other sources are dropped here.
{% if host_boundary_effective.locksmith.enabled | default(true) %}
block drop quick proto tcp from any to any port { $openclaw_pipelock_port, $openclaw_locksmith_port } label "openclaw-host-service-exposure-block"
{% else %}
block drop quick proto tcp from any to any port $openclaw_pipelock_port label "openclaw-host-service-exposure-block"
{% endif %}

# Mandatory VM egress choke point. Anything from either VM that was not admitted
# above is direct egress or lateral movement and is dropped.
block drop quick from $openclaw_gateway to any label "openclaw-gateway-direct-egress-block"
block drop quick from $openclaw_untrusted to any label "openclaw-untrusted-direct-egress-block"
