# Generated by openclaw-hardened host_boundary role
listen:
  host: "{{ host_boundary_effective.locksmith.listen_host }}"
  port: {{ host_boundary_effective.locksmith.listen_port }}

{% set _locksmith_inbound_token = host_boundary_effective.locksmith.inbound_token | default(locksmith.inbound_token | default('')) %}
{% if _locksmith_inbound_token != '' %}
inbound_auth:
  mode: "bearer"
  token: "${LOCKSMITH_INBOUND_TOKEN}"
{% endif %}

egress_proxy: "http://127.0.0.1:{{ host_boundary_pipelock_port }}"

logging:
  level: "{{ host_boundary_effective.locksmith.log_level | default(locksmith.log_level | default('info')) }}"
  file: "{{ host_boundary_effective.log_dir }}/locksmith.log"

tools:
{% set _locksmith_tools = host_boundary_effective.locksmith.tools | default(locksmith.tools | default([])) %}
{% for tool in _locksmith_tools %}
{%   if tool.api_key | default('') != '' or tool.auth_required | default(true) == false %}
  - name: "{{ tool.name }}"
    description: "{{ tool.description | default(tool.name) }}"
    upstream: "{{ tool.upstream }}"
    cloud: {{ tool.cloud | default(true) | to_json }}
{% if tool.api_key | default('') != '' %}
    auth:
      header: "{{ tool.api_key_header | default('Authorization') }}"
      value: "{{ (tool.api_key_prefix ~ ' ') if tool.api_key_prefix | default('') != '' else '' }}${{ '{' }}{{ tool.api_key_env }}{{ '}' }}"
{% endif %}
    timeout_seconds: {{ tool.timeout_seconds | default(30) }}
{%   endif %}
{% endfor %}
