# Generated by openclaw-hardened host_boundary role
{% set _global_locksmith = locksmith | default({}) %}
listen:
  host: "{{ host_boundary_effective.locksmith.listen_host }}"
  port: {{ host_boundary_effective.locksmith.listen_port }}
{% if host_boundary_effective.locksmith.admin_socket_path | default(_global_locksmith.admin_socket_path | default('')) != '' %}
  admin_socket:
    path: "{{ host_boundary_effective.locksmith.admin_socket_path | default(_global_locksmith.admin_socket_path) }}"
{% endif %}

{% set _operator_credentials_path = host_boundary_effective.locksmith.operator_credentials_path | default(_global_locksmith.operator_credentials_path | default('')) %}
{% if _operator_credentials_path != '' %}
operator_credentials_path: "{{ _operator_credentials_path }}"

{% endif %}
{% set _database_path = host_boundary_effective.locksmith.database_path | default(_global_locksmith.database_path | default('')) %}
{% if _database_path != '' %}
database:
  path: "{{ _database_path }}"

{% endif %}
{% set _audit = host_boundary_effective.locksmith.audit | default(_global_locksmith.audit | default({})) %}
{% if _audit | length > 0 %}
audit:
  retention_days: {{ _audit.retention_days | default(90) }}
  sweep_interval_seconds: {{ _audit.sweep_interval_seconds | default(3600) }}

{% endif %}
{% set _locksmith_inbound_token = host_boundary_effective.locksmith.inbound_token | default(_global_locksmith.inbound_token | default('')) %}
{% if _locksmith_inbound_token != '' %}
inbound_auth:
  mode: "bearer"
  token: "${LOCKSMITH_INBOUND_TOKEN}"

{% endif %}
egress_proxy: "http://127.0.0.1:{{ host_boundary_pipelock_port }}"

{% set _locksmith_kamiwaza = host_boundary_effective.locksmith.kamiwaza | default(_global_locksmith.kamiwaza | default({})) %}
{% if _locksmith_kamiwaza.enabled | default(false) %}
{% set _kamiwaza_egress = _locksmith_kamiwaza.egress | default((_locksmith_kamiwaza.cloud | default(false)) | ternary('proxied', 'direct')) %}
kamiwaza:
  enabled: true
{% if _locksmith_kamiwaza.api_url | default('') != '' %}
  api_url: "{{ _locksmith_kamiwaza.api_url }}"
{% endif %}
{% if _locksmith_kamiwaza.api_url_candidates | default([]) | length > 0 %}
  api_url_candidates: {{ _locksmith_kamiwaza.api_url_candidates | to_json }}
{% endif %}
{% if _locksmith_kamiwaza.api_token | default('') != '' or _locksmith_kamiwaza.api_token_from_env | default(false) %}
  api_token: "${{ '{' }}{{ _locksmith_kamiwaza.api_token_env | default('KAMIWAZA_API_KEY') }}{{ '}' }}"
{% endif %}
  tool_prefix: "{{ _locksmith_kamiwaza.tool_prefix | default('kamiwaza') }}"
  include_types: {{ _locksmith_kamiwaza.include_types | default(['tool']) | to_json }}
  verify_tls: {{ _locksmith_kamiwaza.verify_tls | default(true) | to_json }}
  cloud: {{ (_kamiwaza_egress == 'proxied') | to_json }}
  timeout_seconds: {{ _locksmith_kamiwaza.timeout_seconds | default(30) }}

{% endif %}
logging:
  level: "{{ host_boundary_effective.locksmith.log_level | default(_global_locksmith.log_level | default('info')) }}"
  file: "{{ host_boundary_effective.log_dir }}/locksmith.log"

{% set _shutdown = host_boundary_effective.locksmith.shutdown | default(_global_locksmith.shutdown | default({})) %}
shutdown:
  drain_window_seconds: {{ _shutdown.drain_window_seconds | default(30) }}

tools:
{% set _locksmith_tools = host_boundary_effective.locksmith.tools | default(_global_locksmith.tools | default([])) %}
{% for tool in _locksmith_tools %}
{%   if tool.api_key | default('') != '' or tool.auth_required | default(true) == false %}
{%     set _tool_egress = tool.egress | default((tool.cloud | default(true)) | ternary('proxied', 'direct')) %}
  - name: "{{ tool.name }}"
    description: "{{ tool.description | default(tool.name) }}"
    upstream: "{{ tool.upstream }}"
    egress: "{{ _tool_egress }}"
{% if tool.api_key | default('') != '' %}
    auth:
      header: "{{ tool.api_key_header | default('Authorization') }}"
      value:
        from_env:
          var: "{{ tool.api_key_env }}"
{% if tool.api_key_prefix | default('') != '' %}
          prefix: "{{ tool.api_key_prefix }} "
{% endif %}
{% endif %}
    timeouts:
      request_seconds: {{ tool.timeouts.request_seconds | default(tool.timeout_seconds | default(host_boundary_effective.locksmith.timeout_seconds | default(_global_locksmith.timeout_seconds | default(30)))) }}
      idle_seconds: {{ tool.timeouts.idle_seconds | default(tool.idle_timeout_seconds | default(host_boundary_effective.locksmith.idle_timeout_seconds | default(_global_locksmith.idle_timeout_seconds | default(60)))) }}
    body_limit_bytes: {{ tool.body_limit_bytes | default(host_boundary_effective.locksmith.body_limit_bytes | default(_global_locksmith.body_limit_bytes | default(10485760))) }}
{% if tool.response is defined %}
    response:
{{ tool.response | to_nice_yaml(indent=2) | indent(6, true) }}
{% endif %}
{%   endif %}
{% endfor %}
