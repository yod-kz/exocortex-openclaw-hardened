#!/usr/bin/env bash
# Generated by openclaw-hardened host_boundary role.
# This file is root-only because it carries Locksmith inbound and upstream
# credential environment variables. The LaunchDaemon plist is intentionally
# non-secret service metadata.
set -euo pipefail

{% set _global_locksmith = locksmith | default({}) %}
{% set _locksmith_inbound_token = host_boundary_effective.locksmith.inbound_token | default(_global_locksmith.inbound_token | default('')) %}
{% if _locksmith_inbound_token != '' %}
export LOCKSMITH_INBOUND_TOKEN={{ _locksmith_inbound_token | quote }}
{% endif %}
{% set _locksmith_oauth_sealing_key = host_boundary_effective.locksmith.oauth_sealing_key | default(_global_locksmith.oauth_sealing_key | default('')) %}
{% if _locksmith_oauth_sealing_key != '' %}
export LOCKSMITH_OAUTH_SEALING_KEY={{ _locksmith_oauth_sealing_key | quote }}
{% endif %}
{% set _locksmith_tools = host_boundary_effective.locksmith.tools | default(_global_locksmith.tools | default([])) %}
{% for tool in _locksmith_tools %}
{% if tool.api_key_env is defined and tool.api_key | default('') != '' %}
export {{ tool.api_key_env }}={{ tool.api_key | quote }}
{% endif %}
{% endfor %}
{% set _locksmith_kamiwaza = host_boundary_effective.locksmith.kamiwaza | default(_global_locksmith.kamiwaza | default({})) %}
{% if _locksmith_kamiwaza.enabled | default(false) and _locksmith_kamiwaza.api_token | default('') != '' %}
export {{ _locksmith_kamiwaza.api_token_env | default('KAMIWAZA_API_KEY') }}={{ _locksmith_kamiwaza.api_token | quote }}
{% endif %}
{% for env_file in host_boundary_effective.locksmith.env_files | default([]) %}
if [[ -r {{ env_file | quote }} ]]; then
  # shellcheck disable=SC1091
  source {{ env_file | quote }}
fi
{% endfor %}

exec {{ host_boundary_effective.locksmith.daemon_binary_path | default(host_boundary_effective.locksmith.binary_path) | quote }} --config {{ host_boundary_effective.locksmith.config_path | quote }}
