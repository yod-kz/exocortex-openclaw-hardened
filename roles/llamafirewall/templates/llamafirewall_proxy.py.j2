#!/usr/bin/env python3
"""
LlamaFirewall OpenAI-Compatible Multi-Upstream Proxy

Sits between OpenClaw and inference endpoints. Scans all
requests/responses with LlamaFirewall (PromptGuard 2, CodeShield).

Routing: OpenClaw sends to http://localhost:{{ llamafirewall.listen_port }}/{provider_name}/v1/...
The proxy strips the provider prefix and forwards to the real upstream.
{% if telemetry.enabled | default(false) %}

Telemetry: Exports OTel traces and metrics to the collector at
{{ telemetry.host }}:{{ telemetry.otel_collector.http_port }}.
{% endif %}

Generated by openclaw-deploy ansible.
"""
import logging
import json
import os
import time
from contextlib import asynccontextmanager
from datetime import datetime, timezone

import httpx
import uvicorn
from fastapi import FastAPI, Request, Response
from fastapi.responses import StreamingResponse

{% if telemetry.enabled | default(false) %}
from opentelemetry import trace, metrics
from opentelemetry.sdk.trace import TracerProvider
from opentelemetry.sdk.trace.export import BatchSpanProcessor
from opentelemetry.sdk.metrics import MeterProvider
from opentelemetry.sdk.metrics.export import PeriodicExportingMetricReader
from opentelemetry.exporter.otlp.proto.http.trace_exporter import OTLPSpanExporter
from opentelemetry.exporter.otlp.proto.http.metric_exporter import OTLPMetricExporter
from opentelemetry.sdk.resources import Resource
from opentelemetry.trace import StatusCode
{% endif %}

from llamafirewall import (
    LlamaFirewall,
    Role,
    ScanDecision,
    ScannerType,
    UserMessage,
    AssistantMessage,
)

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
    handlers=[
        logging.FileHandler("/var/log/llamafirewall/proxy.log"),
        logging.StreamHandler(),
    ],
)
logger = logging.getLogger("llamafirewall-proxy")

LISTEN_HOST = "{{ llamafirewall.listen_host }}"
LISTEN_PORT = {{ llamafirewall.listen_port }}

# ── Upstream routing table ────────────────────────────────────
{# Filter: LAN always active, cloud only if key is configured #}
{% set _eps = [] %}
{% for ep in inference.endpoints %}
{%   if ep.api_key | default('not-required') != '' %}
{%     set _ = _eps.append(ep) %}
{%   endif %}
{% endfor %}
UPSTREAMS = {
{% for ep in _eps %}
    "{{ ep.provider_name }}": {
        "base_url": "{{ ep.base_url }}",
        "verify_tls": {% if ep.tls_skip_verify %}False{% else %}True{% endif %},
        "cloud": {{ (ep.location | default('lan') == 'cloud') | to_json | capitalize }},
        "api_key": {{ ('"%s"' % ep.api_key) if ep.api_key is defined else 'None' }},
        "api_key_header": {{ ('"%s"' % ep.api_key_header) if ep.api_key_header is defined else 'None' }},
        "api_key_prefix": {{ ('"%s"' % ep.api_key_prefix) if ep.api_key_prefix is defined else 'None' }},
        "api_type": "{{ ep.api_type }}",
    },
{% endfor %}
}

PIPELOCK_PROXY = "http://{{ pipelock.listen }}"

# ── Budget enforcement ────────────────────────────────────────
{% if llamafirewall.budget.enabled | default(false) %}
BUDGET_ENABLED = True
BUDGET_STATE_FILE = "{{ llamafirewall.budget.state_file }}"
BUDGET_DEFAULT_MONTHLY_USD = {{ llamafirewall.budget.default_monthly_usd }}

PROVIDER_COSTS = {
{% for ep in _eps %}
{% if ep.cost_per_1m_input_tokens is defined %}
    "{{ ep.provider_name }}": {
        "input_per_1m": {{ ep.cost_per_1m_input_tokens }},
        "output_per_1m": {{ ep.cost_per_1m_output_tokens }},
        "monthly_usd": {{ ep.budget_monthly_usd | default(llamafirewall.budget.default_monthly_usd) }},
    },
{% endif %}
{% endfor %}
}

_budget_state = {"month": "", "providers": {}}


def _current_month():
    return datetime.now(timezone.utc).strftime("%Y-%m")


def _load_budget_state():
    global _budget_state
    try:
        with open(BUDGET_STATE_FILE) as f:
            _budget_state = json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        _budget_state = {"month": _current_month(), "providers": {}}
    if _budget_state.get("month") != _current_month():
        logger.info("Monthly budget reset: %s -> %s",
                     _budget_state.get("month"), _current_month())
        _budget_state = {"month": _current_month(), "providers": {}}
        _save_budget_state()


def _save_budget_state():
    tmp = BUDGET_STATE_FILE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(_budget_state, f, indent=2)
    os.replace(tmp, BUDGET_STATE_FILE)


def _get_provider_spend(provider_name):
    prov = _budget_state["providers"].get(provider_name, {})
    return prov.get("cost_usd", 0.0)


def _get_provider_limit(provider_name):
    if provider_name in PROVIDER_COSTS:
        return PROVIDER_COSTS[provider_name]["monthly_usd"]
    return BUDGET_DEFAULT_MONTHLY_USD


def _check_budget(provider_name):
    """Returns (allowed, current_spend, limit)."""
    if provider_name not in PROVIDER_COSTS:
        return True, 0.0, 0.0  # no cost config = no limit
    cost_cfg = PROVIDER_COSTS[provider_name]
    if cost_cfg["input_per_1m"] == 0 and cost_cfg["output_per_1m"] == 0:
        return True, 0.0, 0.0  # zero-cost provider
    limit = cost_cfg["monthly_usd"]
    spent = _get_provider_spend(provider_name)
    return spent < limit, spent, limit


def _record_cost(provider_name, input_tokens, output_tokens):
    if provider_name not in PROVIDER_COSTS:
        return
    cost_cfg = PROVIDER_COSTS[provider_name]
    cost = (input_tokens * cost_cfg["input_per_1m"] / 1_000_000
            + output_tokens * cost_cfg["output_per_1m"] / 1_000_000)
    if cost == 0:
        return
    prov = _budget_state["providers"].setdefault(provider_name, {
        "input_tokens": 0, "output_tokens": 0, "cost_usd": 0.0,
    })
    prov["input_tokens"] += input_tokens
    prov["output_tokens"] += output_tokens
    prov["cost_usd"] += cost
    _save_budget_state()
    logger.info("Budget [%s]: +$%.4f  total=$%.2f / $%.2f",
                provider_name, cost, prov["cost_usd"],
                cost_cfg["monthly_usd"])


def _extract_streaming_usage(provider_name, content):
    """Parse SSE stream for token usage.

    OpenAI: usage in final data chunk (requires stream_options.include_usage).
    Anthropic: input_tokens in message_start, output_tokens in message_delta.
    """
    try:
        text = content.decode("utf-8", errors="replace")
        input_tokens = 0
        output_tokens = 0

        for line in text.splitlines():
            if not line.startswith("data: ") or line.strip() == "data: [DONE]":
                continue
            try:
                chunk = json.loads(line[6:])
            except json.JSONDecodeError:
                continue

            # OpenAI: single usage block in final chunk
            usage = chunk.get("usage")
            if usage:
                input_tokens = max(input_tokens,
                    usage.get("prompt_tokens", 0) or usage.get("input_tokens", 0))
                output_tokens = max(output_tokens,
                    usage.get("completion_tokens", 0) or usage.get("output_tokens", 0))

            # Anthropic: input_tokens in message_start.message.usage
            msg = chunk.get("message", {})
            if msg.get("usage", {}).get("input_tokens"):
                input_tokens = max(input_tokens, msg["usage"]["input_tokens"])

        if input_tokens or output_tokens:
{% if telemetry.enabled | default(false) %}
            m_tokens_counter.add(input_tokens,
                                 {"provider": provider_name, "type": "prompt"})
            m_tokens_counter.add(output_tokens,
                                 {"provider": provider_name, "type": "completion"})
{% endif %}
            _record_cost(provider_name, input_tokens, output_tokens)
            logger.debug("Streaming usage [%s]: in=%d out=%d",
                         provider_name, input_tokens, output_tokens)
        else:
            logger.debug("No usage found in streaming response for %s", provider_name)
    except Exception as e:
        logger.warning("Failed to extract streaming usage for %s: %s",
                       provider_name, e)
{% else %}
BUDGET_ENABLED = False
{% endif %}

{% if telemetry.enabled | default(false) %}
# ── OpenTelemetry setup ─────────────────────────────────────────
OTEL_ENDPOINT = "http://{{ telemetry.host }}:{{ telemetry.otel_collector.http_port }}"

_resource = Resource.create({
    "service.name": "llamafirewall-proxy",
    "service.version": "1.0.0",
    "deployment.environment": "openclaw-hardened",
})

_tracer_provider = TracerProvider(resource=_resource)
_tracer_provider.add_span_processor(
    BatchSpanProcessor(OTLPSpanExporter(endpoint=f"{OTEL_ENDPOINT}/v1/traces"))
)
trace.set_tracer_provider(_tracer_provider)
_tracer = trace.get_tracer("llamafirewall-proxy")

_metric_reader = PeriodicExportingMetricReader(
    OTLPMetricExporter(endpoint=f"{OTEL_ENDPOINT}/v1/metrics"),
    export_interval_millis=10000,
)
_meter_provider = MeterProvider(resource=_resource, metric_readers=[_metric_reader])
metrics.set_meter_provider(_meter_provider)
_meter = metrics.get_meter("llamafirewall-proxy")

m_request_duration = _meter.create_histogram(
    "llamafirewall.request.duration", unit="s",
    description="Total request duration end-to-end")
m_input_scan_duration = _meter.create_histogram(
    "llamafirewall.input_scan.duration", unit="s",
    description="PromptGuard input scan duration")
m_upstream_duration = _meter.create_histogram(
    "llamafirewall.upstream.duration", unit="s",
    description="Upstream inference call duration")
m_output_scan_duration = _meter.create_histogram(
    "llamafirewall.output_scan.duration", unit="s",
    description="CodeShield output scan duration")
m_request_counter = _meter.create_counter(
    "llamafirewall.requests",
    description="Total requests by provider and status")
m_tokens_counter = _meter.create_counter(
    "llamafirewall.tokens",
    description="Token counts from inference responses")
m_scan_block_counter = _meter.create_counter(
    "llamafirewall.scan_blocks",
    description="Requests blocked by LlamaFirewall")
{% endif %}

# ── Configure scanners per role ───────────────────────────────
scanners = {}
input_scanners = []
output_scanners = []
{% if llamafirewall.promptguard.enabled %}
input_scanners.append(ScannerType.PROMPT_GUARD)
{% endif %}
{% if llamafirewall.codeshield.enabled %}
output_scanners.append(ScannerType.CODE_SHIELD)
{% endif %}
if input_scanners:
    scanners[Role.USER] = input_scanners
if output_scanners:
    scanners[Role.ASSISTANT] = output_scanners

firewall = None
clients = {}


@asynccontextmanager
async def lifespan(app: FastAPI):
    global firewall, clients
    logger.info("Initializing LlamaFirewall with scanners: %s", scanners)
    firewall = LlamaFirewall(scanners=scanners)

    for name, upstream in UPSTREAMS.items():
        client_headers = {}
        if upstream["api_key"]:
            prefix = f'{upstream["api_key_prefix"]} ' if upstream["api_key_prefix"] else ""
            client_headers[upstream["api_key_header"]] = f"{prefix}{upstream['api_key']}"
        if upstream["api_type"] == "anthropic":
            client_headers["anthropic-version"] = "2023-06-01"

        clients[name] = httpx.AsyncClient(
            base_url=upstream["base_url"],
            verify=upstream["verify_tls"],
            timeout=120.0,
            proxy=PIPELOCK_PROXY if upstream["cloud"] else None,
            headers=client_headers or None,
        )
        logger.info("Upstream registered: %s -> %s (verify_tls=%s, cloud=%s)",
                     name, upstream["base_url"], upstream["verify_tls"],
                     upstream["cloud"])

    if BUDGET_ENABLED:
        _load_budget_state()
        for pname in PROVIDER_COSTS:
            allowed, spent, limit = _check_budget(pname)
            logger.info("Budget [%s]: $%.2f / $%.2f %s",
                         pname, spent, limit,
                         "OK" if allowed else "EXHAUSTED")

    logger.info("LlamaFirewall proxy ready — %d upstreams", len(clients))
    yield
    for client in clients.values():
        await client.aclose()
{% if telemetry.enabled | default(false) %}
    _tracer_provider.shutdown()
    _meter_provider.shutdown()
{% endif %}


app = FastAPI(lifespan=lifespan)


@app.get("/health")
async def health():
    return {"status": "ok", "upstreams": list(UPSTREAMS.keys())}


@app.get("/budget")
async def budget():
    if not BUDGET_ENABLED:
        return {"enabled": False}
    _load_budget_state()  # refresh in case of manual edits
    summary = {}
    for pname, cfg in PROVIDER_COSTS.items():
        spent = _get_provider_spend(pname)
        limit = cfg["monthly_usd"]
        summary[pname] = {
            "spent_usd": round(spent, 4),
            "limit_usd": limit,
            "remaining_usd": round(max(0, limit - spent), 4),
            "exhausted": spent >= limit,
        }
    return {"enabled": True, "month": _budget_state.get("month"), "providers": summary}


def _record_request(provider, status, path, elapsed):
{% if telemetry.enabled | default(false) %}
    m_request_counter.add(1, {"provider": provider, "status": str(status)})
    m_request_duration.record(elapsed, {"provider": provider, "path": path})
{% else %}
    pass
{% endif %}


@app.api_route("/{provider_name}/{path:path}", methods=["GET", "POST", "PUT", "DELETE"])
async def proxy(request: Request, provider_name: str, path: str):
    """Route request to upstream by provider name, scanning with LlamaFirewall."""
    t_start = time.monotonic()

    client = clients.get(provider_name)
    if client is None:
        return Response(
            content=json.dumps({"error": {"message": f"Unknown provider: {provider_name}"}}),
            status_code=404,
            media_type="application/json",
        )

    # Strip v1/ prefix — base_url already includes /v1
    if path.startswith("v1/"):
        path = path[3:]

    # Strip headers that the client manages (host, auth for cloud endpoints)
    skip_headers = {"host", "content-length"}
    if UPSTREAMS[provider_name]["api_key"]:
        skip_headers.add(UPSTREAMS[provider_name]["api_key_header"].lower())
    fwd_hdr = {k: v for k, v in request.headers.items() if k.lower() not in skip_headers}

{% if telemetry.enabled | default(false) %}
    span = _tracer.start_span(
        f"llamafirewall.proxy.{path}",
        attributes={
            "llamafirewall.provider": provider_name,
            "llamafirewall.path": path,
            "http.method": request.method,
            "llamafirewall.cloud": UPSTREAMS[provider_name]["cloud"],
        },
    )
{% endif %}

    try:
        return await _handle_request(
            request, client, provider_name, path, fwd_hdr, t_start)
    finally:
{% if telemetry.enabled | default(false) %}
        span.end()
{% else %}
        pass
{% endif %}


async def _handle_request(request, client, provider_name, path, fwd_hdr, t_start):
    # ── Budget gate ───────────────────────────────────────────
    if BUDGET_ENABLED:
        allowed, spent, limit = _check_budget(provider_name)
        if not allowed:
            logger.warning("BUDGET EXCEEDED [%s]: $%.2f / $%.2f",
                           provider_name, spent, limit)
            _record_request(provider_name, 429, path, time.monotonic() - t_start)
            return Response(
                content=json.dumps({
                    "error": {
                        "message": (f"Monthly budget exceeded for {provider_name}: "
                                    f"${spent:.2f} / ${limit:.2f}"),
                        "type": "budget_exceeded",
                        "spent_usd": round(spent, 4),
                        "limit_usd": limit,
                    }
                }),
                status_code=429,
                media_type="application/json",
            )

    # ── Forward non-chat requests directly ────────────────────
    if path not in ("chat/completions", "messages"):
        resp = await client.request(
            method=request.method,
            url=f"/{path}",
            headers=fwd_hdr,
            content=await request.body(),
        )
        _record_request(provider_name, resp.status_code, path, time.monotonic() - t_start)
        return Response(
            content=resp.content,
            status_code=resp.status_code,
            headers=dict(resp.headers),
        )

    # ── Chat completions: scan input ──────────────────────────
    body = await request.json()
    messages = body.get("messages", [])

    user_messages = [m for m in messages if m.get("role") == "user"]
    if user_messages and firewall:
        last_user = user_messages[-1]
        content = last_user.get("content", "")
        if isinstance(content, str) and content.strip():
            try:
                t_scan = time.monotonic()
                result = firewall.scan(UserMessage(content=content))
                scan_elapsed = time.monotonic() - t_scan
{% if telemetry.enabled | default(false) %}
                m_input_scan_duration.record(scan_elapsed, {"provider": provider_name})
                span = trace.get_current_span()
                span.set_attribute("llamafirewall.input_scan.duration_s", scan_elapsed)
                span.set_attribute("llamafirewall.input_scan.decision", str(result.decision))
                span.set_attribute("llamafirewall.input_scan.score", result.score)
{% endif %}
                if result.decision == ScanDecision.BLOCK:
                    logger.warning(
                        "BLOCKED [%s]: reason=%s score=%.3f content_preview=%.100s",
                        provider_name, result.reason, result.score, content,
                    )
{% if telemetry.enabled | default(false) %}
                    m_scan_block_counter.add(1, {"provider": provider_name, "stage": "input"})
                    span.set_status(StatusCode.ERROR, f"Blocked: {result.reason}")
{% endif %}
                    _record_request(provider_name, 403, path, time.monotonic() - t_start)
                    return Response(
                        content=json.dumps({
                            "error": {
                                "message": f"Request blocked by LlamaFirewall: {result.reason}",
                                "type": "security_block",
                                "score": result.score,
                            }
                        }),
                        status_code=403,
                        media_type="application/json",
                    )
                logger.debug("Input scan PASS [%s]: score=%.3f", provider_name, result.score)
            except Exception as e:
                logger.error("LlamaFirewall scan error (allowing request): %s", e)

    # ── Forward to upstream ───────────────────────────────────
    stream = body.get("stream", False)

    if stream:
        # Ask upstream for usage stats in the final SSE chunk so we
        # can track budget even on streaming responses.
        # Anthropic always includes usage; OpenAI needs stream_options.
        if (BUDGET_ENABLED and provider_name in PROVIDER_COSTS
                and UPSTREAMS[provider_name]["api_type"] != "anthropic"):
            body.setdefault("stream_options", {})["include_usage"] = True

        t_upstream = time.monotonic()
        upstream_resp = await client.request(
            method="POST", url=f"/{path}", json=body, headers=fwd_hdr,
        )
{% if telemetry.enabled | default(false) %}
        m_upstream_duration.record(time.monotonic() - t_upstream, {"provider": provider_name})
{% endif %}
        _record_request(provider_name, upstream_resp.status_code, path, time.monotonic() - t_start)

        # The response is already fully buffered by httpx. Parse SSE
        # chunks for token usage before streaming back to client.
        if BUDGET_ENABLED and provider_name in PROVIDER_COSTS:
            _extract_streaming_usage(provider_name, upstream_resp.content)

        return StreamingResponse(
            content=upstream_resp.aiter_bytes(),
            status_code=upstream_resp.status_code,
            headers=dict(upstream_resp.headers),
        )

    t_upstream = time.monotonic()
    resp = await client.request(
        method="POST", url=f"/{path}", json=body, headers=fwd_hdr,
    )
    upstream_elapsed = time.monotonic() - t_upstream
{% if telemetry.enabled | default(false) %}
    m_upstream_duration.record(upstream_elapsed, {"provider": provider_name})
{% endif %}
    resp_body = resp.json()

    # Record token usage and budget
    # OpenAI: prompt_tokens/completion_tokens; Anthropic: input_tokens/output_tokens
    usage = resp_body.get("usage", {})
    if usage:
        prompt_tokens = usage.get("prompt_tokens", 0) or usage.get("input_tokens", 0)
        completion_tokens = usage.get("completion_tokens", 0) or usage.get("output_tokens", 0)
{% if telemetry.enabled | default(false) %}
        m_tokens_counter.add(prompt_tokens, {"provider": provider_name, "type": "prompt"})
        m_tokens_counter.add(completion_tokens, {"provider": provider_name, "type": "completion"})
        span = trace.get_current_span()
        span.set_attribute("llm.usage.prompt_tokens", prompt_tokens)
        span.set_attribute("llm.usage.completion_tokens", completion_tokens)
{% endif %}
        if BUDGET_ENABLED:
            _record_cost(provider_name, prompt_tokens, completion_tokens)

    # Scan assistant response
    # OpenAI: choices[0].message.content; Anthropic: content[0].text
    assistant_content = ""
    is_anthropic = "content" in resp_body and "choices" not in resp_body
    if is_anthropic:
        content_blocks = resp_body.get("content", [])
        assistant_content = " ".join(
            b.get("text", "") for b in content_blocks if b.get("type") == "text"
        )
    else:
        choices = resp_body.get("choices", [])
        if choices:
            assistant_content = choices[0].get("message", {}).get("content", "")

    if firewall and isinstance(assistant_content, str) and assistant_content.strip():
        try:
            t_scan = time.monotonic()
            result = firewall.scan(AssistantMessage(content=assistant_content))
            scan_elapsed = time.monotonic() - t_scan
{% if telemetry.enabled | default(false) %}
            m_output_scan_duration.record(scan_elapsed, {"provider": provider_name})
            span = trace.get_current_span()
            span.set_attribute("llamafirewall.output_scan.duration_s", scan_elapsed)
            span.set_attribute("llamafirewall.output_scan.decision", str(result.decision))
{% endif %}
            if result.decision == ScanDecision.BLOCK:
                logger.warning(
                    "BLOCKED output [%s]: reason=%s score=%.3f",
                    provider_name, result.reason, result.score,
                )
{% if telemetry.enabled | default(false) %}
                m_scan_block_counter.add(1, {"provider": provider_name, "stage": "output"})
                span.set_status(StatusCode.ERROR, f"Output blocked: {result.reason}")
{% endif %}
                blocked_msg = "[Response blocked by security scanner]"
                if is_anthropic:
                    resp_body["content"] = [{"type": "text", "text": blocked_msg}]
                else:
                    resp_body["choices"][0]["message"]["content"] = blocked_msg
        except Exception as e:
            logger.error("Output scan error (allowing response): %s", e)

    _record_request(provider_name, resp.status_code, path, time.monotonic() - t_start)
    return Response(
        content=json.dumps(resp_body),
        status_code=resp.status_code,
        media_type="application/json",
    )


if __name__ == "__main__":
    uvicorn.run(app, host=LISTEN_HOST, port=LISTEN_PORT)
