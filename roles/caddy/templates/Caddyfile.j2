# Generated by openclaw-deploy ansible
# Caddy — TLS reverse proxy for telemetry UIs
{
	auto_https disable_redirects
	local_certs
}

https://{{ ansible_host }}:{{ telemetry.caddy.grafana_port }} {
	tls internal
	reverse_proxy {{ telemetry.host }}:{{ telemetry.grafana.port }}
}

https://{{ ansible_host }}:{{ telemetry.caddy.prometheus_port }} {
	tls internal
	reverse_proxy {{ telemetry.host }}:{{ telemetry.prometheus.port }}
}

https://{{ ansible_host }}:{{ telemetry.caddy.phoenix_port }} {
	tls internal
	reverse_proxy {{ telemetry.host }}:{{ telemetry.phoenix.port }}
}
