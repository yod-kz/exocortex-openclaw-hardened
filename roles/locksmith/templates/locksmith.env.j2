# Generated by openclaw-hardened. Root-owned because it carries Locksmith
# inbound authority and upstream tool credentials.

{% for tool in locksmith.tools %}
{% if tool.api_key_env is defined and tool.api_key | default('') != '' %}
{{ tool.api_key_env }}={{ tool.api_key | quote }}
{% endif %}
{% endfor %}
{% if locksmith.inbound_token | default('') != '' %}
LOCKSMITH_INBOUND_TOKEN={{ locksmith.inbound_token | quote }}
{% endif %}
{% if locksmith.oauth_sealing_key | default('') != '' %}
LOCKSMITH_OAUTH_SEALING_KEY={{ locksmith.oauth_sealing_key | quote }}
{% endif %}
{% if locksmith.kamiwaza.enabled | default(false) and locksmith.kamiwaza.api_token | default('') != '' %}
{{ locksmith.kamiwaza.api_token_env | default('KAMIWAZA_API_KEY') }}={{ locksmith.kamiwaza.api_token | quote }}
{% endif %}
