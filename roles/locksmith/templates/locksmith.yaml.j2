# Generated by openclaw-deploy ansible for {{ inventory_hostname }}
listen:
  host: "{{ locksmith.listen_host | default('127.0.0.1') }}"
  port: {{ locksmith.listen_port | default(9200) }}
{% if locksmith.admin_socket_path | default('') != '' %}
  admin_socket:
    path: "{{ locksmith.admin_socket_path }}"
{% endif %}

{% if locksmith.operator_credentials_path | default('') != '' %}
operator_credentials_path: "{{ locksmith.operator_credentials_path }}"

{% endif %}
{% if locksmith.database_path | default('') != '' %}
database:
  path: "{{ locksmith.database_path }}"

{% endif %}
{% if locksmith.audit is defined %}
audit:
  retention_days: {{ locksmith.audit.retention_days | default(90) }}
  sweep_interval_seconds: {{ locksmith.audit.sweep_interval_seconds | default(3600) }}

{% endif %}
{% if locksmith.inbound_token | default('') != '' %}
inbound_auth:
  mode: "bearer"
  token: "${LOCKSMITH_INBOUND_TOKEN}"

{% endif %}
egress_proxy: "http://127.0.0.1:{{ pipelock.listen.split(':')[-1] }}"

{% if locksmith.kamiwaza.enabled | default(false) %}
{% set _kamiwaza_egress = locksmith.kamiwaza.egress | default((locksmith.kamiwaza.cloud | default(false)) | ternary('proxied', 'direct')) %}
kamiwaza:
  enabled: true
{% if locksmith.kamiwaza.api_url | default('') != '' %}
  api_url: "{{ locksmith.kamiwaza.api_url }}"
{% endif %}
{% if locksmith.kamiwaza.api_url_candidates | default([]) | length > 0 %}
  api_url_candidates: {{ locksmith.kamiwaza.api_url_candidates | to_json }}
{% endif %}
{% if locksmith.kamiwaza.api_token | default('') != '' or locksmith.kamiwaza.api_token_from_env | default(false) %}
  api_token: "${{ '{' }}{{ locksmith.kamiwaza.api_token_env | default('KAMIWAZA_API_KEY') }}{{ '}' }}"
{% endif %}
  tool_prefix: "{{ locksmith.kamiwaza.tool_prefix | default('kamiwaza') }}"
  include_types: {{ locksmith.kamiwaza.include_types | default(['tool']) | to_json }}
  verify_tls: {{ locksmith.kamiwaza.verify_tls | default(true) | to_json }}
  cloud: {{ (_kamiwaza_egress == 'proxied') | to_json }}
  timeout_seconds: {{ locksmith.kamiwaza.timeout_seconds | default(30) }}

{% endif %}
logging:
  level: "{{ locksmith.log_level | default('info') }}"
  file: "/var/log/locksmith/proxy.log"

shutdown:
  drain_window_seconds: {{ locksmith.shutdown.drain_window_seconds | default(30) }}

tools:
{% set _slack_native = locksmith.slack_native | default({}) %}
{% set _slack_native_enabled = _slack_native.enabled | default(true) %}
{% set _slack_bot_handles = _slack_native.bot_handles | default([]) | list %}
{% set _slack_app_handles = _slack_native.app_handles | default([]) | list %}
{% set _slack_user_handles = _slack_native.user_handles | default([]) | list %}
{% if _slack_native_enabled %}
{%   for agent in openclaw_agents | default([]) %}
{%     if agent.slack is defined %}
{%       set _agent_slack = agent.slack | default({}) %}
{%       set _agent_slack_proxy = _agent_slack.credential_proxy | default({}) %}
{%       set _ = _slack_bot_handles.append(_agent_slack_proxy.bot_handle | default(_agent_slack.bot_handle | default('xoxb-locksmith-' ~ agent.id))) %}
{%       set _ = _slack_app_handles.append(_agent_slack_proxy.app_handle | default(_agent_slack.app_handle | default('xapp-locksmith-' ~ agent.id))) %}
{%       if _slack_native.include_user | default(false) or _agent_slack.user_token | default('') != '' or _agent_slack.user_handle | default('') != '' or _agent_slack_proxy.user_handle | default('') != '' %}
{%         set _ = _slack_user_handles.append(_agent_slack_proxy.user_handle | default(_agent_slack.user_handle | default('xoxp-locksmith-' ~ agent.id))) %}
{%       endif %}
{%     endif %}
{%   endfor %}
{% endif %}
{% if _slack_native_enabled and _slack_bot_handles | length > 0 %}
  - name: "{{ _slack_native.bot_tool_name | default('slack-bot') }}"
    description: "Slack bot Web API credential transport"
    upstream: "{{ _slack_native.upstream | default('https://slack.com/api') }}"
    egress: "proxied"
    credential_handles:
{%   for handle in _slack_bot_handles | unique %}
      - "{{ handle }}"
{%   endfor %}
    auth:
      header: "Authorization"
      force_replace: true
      value:
        from_env:
          var: "{{ _slack_native.bot_token_env | default('SLACK_BOT_TOKEN') }}"
          prefix: "Bearer "
    timeouts:
      request_seconds: {{ _slack_native.request_seconds | default(locksmith.timeout_seconds | default(60)) }}
      idle_seconds: {{ _slack_native.idle_seconds | default(locksmith.idle_timeout_seconds | default(60)) }}
    body_limit_bytes: {{ _slack_native.body_limit_bytes | default(locksmith.body_limit_bytes | default(10485760)) }}
{% endif %}
{% if _slack_native_enabled and _slack_app_handles | length > 0 %}
  - name: "{{ _slack_native.app_tool_name | default('slack-app') }}"
    description: "Slack app-token Web API credential transport"
    upstream: "{{ _slack_native.upstream | default('https://slack.com/api') }}"
    egress: "proxied"
    credential_handles:
{%   for handle in _slack_app_handles | unique %}
      - "{{ handle }}"
{%   endfor %}
    auth:
      header: "Authorization"
      force_replace: true
      value:
        from_env:
          var: "{{ _slack_native.app_token_env | default('SLACK_APP_TOKEN') }}"
          prefix: "Bearer "
    timeouts:
      request_seconds: {{ _slack_native.request_seconds | default(locksmith.timeout_seconds | default(60)) }}
      idle_seconds: {{ _slack_native.idle_seconds | default(locksmith.idle_timeout_seconds | default(60)) }}
    body_limit_bytes: {{ _slack_native.body_limit_bytes | default(locksmith.body_limit_bytes | default(10485760)) }}
{% endif %}
{% if _slack_native_enabled and _slack_user_handles | length > 0 %}
  - name: "{{ _slack_native.user_tool_name | default('slack-user') }}"
    description: "Slack user-token Web API credential transport"
    upstream: "{{ _slack_native.upstream | default('https://slack.com/api') }}"
    egress: "proxied"
    credential_handles:
{%   for handle in _slack_user_handles | unique %}
      - "{{ handle }}"
{%   endfor %}
    auth:
      header: "Authorization"
      force_replace: true
      value:
        from_env:
          var: "{{ _slack_native.user_token_env | default('SLACK_USER_TOKEN') }}"
          prefix: "Bearer "
    timeouts:
      request_seconds: {{ _slack_native.request_seconds | default(locksmith.timeout_seconds | default(60)) }}
      idle_seconds: {{ _slack_native.idle_seconds | default(locksmith.idle_timeout_seconds | default(60)) }}
    body_limit_bytes: {{ _slack_native.body_limit_bytes | default(locksmith.body_limit_bytes | default(10485760)) }}
{% endif %}
{% for tool in locksmith.tools %}
{%   if tool.api_key | default('') != '' or tool.api_key_from_env | default(false) or tool.auth_required | default(true) == false %}
{%     set _tool_egress = tool.egress | default((tool.cloud | default(true)) | ternary('proxied', 'direct')) %}
  - name: "{{ tool.name }}"
    description: "{{ tool.description | default(tool.name) }}"
    upstream: "{{ tool.upstream }}"
    egress: "{{ _tool_egress }}"
{% if tool.credential_handles is defined and tool.credential_handles | length > 0 %}
    credential_handles: {{ tool.credential_handles | to_json }}
{% endif %}
{% if tool.api_key | default('') != '' or tool.api_key_from_env | default(false) %}
    auth:
      header: "{{ tool.api_key_header | default('Authorization') }}"
      force_replace: {{ tool.force_replace | default(false) | to_json }}
      value:
        from_env:
          var: "{{ tool.api_key_env }}"
{% if tool.api_key_prefix | default('') != '' %}
          prefix: "{{ tool.api_key_prefix }} "
{% endif %}
{% endif %}
    timeouts:
      request_seconds: {{ tool.timeouts.request_seconds | default(tool.timeout_seconds | default(locksmith.timeout_seconds | default(30))) }}
      idle_seconds: {{ tool.timeouts.idle_seconds | default(tool.idle_timeout_seconds | default(locksmith.idle_timeout_seconds | default(60))) }}
    body_limit_bytes: {{ tool.body_limit_bytes | default(locksmith.body_limit_bytes | default(10485760)) }}
{% if tool.response is defined %}
    response:
{{ tool.response | to_nice_yaml(indent=2) | indent(6, true) }}
{% endif %}
{%   endif %}
{% endfor %}
