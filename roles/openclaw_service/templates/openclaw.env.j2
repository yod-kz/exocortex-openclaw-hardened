# Generated by openclaw-hardened. Root-owned because it may contain scoped
# Locksmith inbound authority. It must not contain raw upstream API keys.

{% if inference.endpoints | selectattr('tls_skip_verify', 'equalto', true) | list | length > 0 %}
NODE_TLS_REJECT_UNAUTHORIZED=0
{% endif %}

# Node.js needs --use-env-proxy to honor HTTP_PROXY/HTTPS_PROXY.
NODE_OPTIONS=--use-env-proxy
HTTP_PROXY=http://127.0.0.1:{{ pipelock.listen.split(':')[1] }}
HTTPS_PROXY=http://127.0.0.1:{{ pipelock.listen.split(':')[1] }}
NO_PROXY=localhost,127.0.0.1,172.17.0.1,{{ network.allowed_lan_ips | map(attribute='ip') | join(',') }}
{% if locksmith.enabled | default(false) and locksmith.inbound_token | default('') != '' %}
LOCKSMITH_INBOUND_TOKEN={{ locksmith.inbound_token | quote }}
{% endif %}
